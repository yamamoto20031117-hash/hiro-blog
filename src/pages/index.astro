---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import AffiliateBox from '@/components/AffiliateBox.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
const sortedPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const latestPosts = sortedPosts.slice(0, 6);
const featuredPost = sortedPosts.find(p => p.data.featured) ?? sortedPosts[0];

// カテゴリ別の最新記事（各2件）
const uberPosts    = sortedPosts.filter(p => p.data.category === 'Uber稼ぎ方').slice(0, 2);
const creditPosts  = sortedPosts.filter(p => p.data.category === 'クレカ修行').slice(0, 2);
const taxPosts     = sortedPosts.filter(p => p.data.category === '扶養・税金').slice(0, 2);

const categories = [
  { label: 'Uber稼ぎ方',  slug: 'uber',        icon: '🚗', color: 'green',  posts: uberPosts,   desc: 'Uberの効率的な稼ぎ方' },
  { label: 'クレカ修行',   slug: 'credit-card', icon: '💳', color: 'blue',   posts: creditPosts, desc: 'マイル・ポイント最大化' },
  { label: '扶養・税金',   slug: 'tax',         icon: '📊', color: 'orange', posts: taxPosts,    desc: '副業と税金の正しい知識' },
];

const colorMap: Record<string, { bg: string; text: string; border: string; btn: string }> = {
  green:  { bg: 'bg-green-50',  text: 'text-green-700',  border: 'border-green-200', btn: 'bg-green-600 hover:bg-green-700' },
  blue:   { bg: 'bg-blue-50',   text: 'text-blue-700',   border: 'border-blue-200',  btn: 'bg-blue-600 hover:bg-blue-700' },
  orange: { bg: 'bg-orange-50', text: 'text-orange-700', border: 'border-orange-200', btn: 'bg-orange-500 hover:bg-orange-600' },
};
---

<BaseLayout title="人生のライフハック - 副業・節約・クレカ活用のリアルな情報サイト">

  <!-- ヒーローセクション -->
  <section class="bg-gradient-to-br from-primary-700 to-primary-900 text-white py-12 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-primary-200 text-xs font-semibold tracking-widest mb-3 uppercase">名大院生・ひろが発信する等身大ライフハック</p>
      <h1 class="text-2xl sm:text-4xl font-bold mb-4 leading-tight">
        💡 人生のライフハック
      </h1>
      <p class="text-primary-100 text-sm sm:text-base max-w-xl mx-auto leading-relaxed mb-2">
        副業・節約・クレカ活用など、実体験にもとづくお得情報を発信中。
      </p>
      <p class="text-primary-200 text-xs sm:text-sm max-w-xl mx-auto leading-relaxed mb-6">
        今イチオシは「原付Uber Eats × クレカ修行」で時給¥2,000 & ゴールドカード年会費無料を同時達成する方法📊
      </p>
      <!-- カテゴリボタン -->
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/category/uber"
          class="bg-green-400 hover:bg-green-300 text-green-900 text-sm font-bold px-5 py-2.5 rounded-full transition-colors shadow">
          🚗 Uber稼ぎ方
        </a>
        <a href="/category/credit-card"
          class="bg-blue-400 hover:bg-blue-300 text-blue-900 text-sm font-bold px-5 py-2.5 rounded-full transition-colors shadow">
          💳 クレカ修行
        </a>
        <a href="/category/tax"
          class="bg-orange-400 hover:bg-orange-300 text-orange-900 text-sm font-bold px-5 py-2.5 rounded-full transition-colors shadow">
          📊 扶養・税金
        </a>
      </div>
    </div>
  </section>

  <div class="max-w-5xl mx-auto px-4 py-10 space-y-14">

    <!-- 注目記事（フィーチャード） -->
    {featuredPost && (
      <section>
        <h2 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
          <span class="w-1 h-5 bg-accent-500 rounded-full inline-block"></span>
          注目記事
        </h2>
        <a href={`/posts/${featuredPost.slug}`}
          class="block bg-white rounded-2xl shadow-md hover:shadow-lg transition-shadow overflow-hidden group">
          <div class="sm:flex">
            <div class="sm:w-2/5 h-48 sm:h-auto flex-shrink-0 overflow-hidden">
              {featuredPost.data.heroImage ? (
                <img
                  src={featuredPost.data.heroImage}
                  alt={featuredPost.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                />
              ) : (
                <div class="w-full h-full bg-gradient-to-br from-primary-100 to-primary-200 flex items-center justify-center text-6xl">
                  {featuredPost.data.category === 'Uber稼ぎ方' ? '🚗' :
                   featuredPost.data.category === 'クレカ修行' ? '💳' :
                   featuredPost.data.category === '扶養・税金' ? '📊' : '📝'}
                </div>
              )}
            </div>
            <div class="p-6 flex flex-col justify-center">
              {featuredPost.data.category && (
                <span class="inline-block bg-primary-100 text-primary-700 text-xs font-semibold px-3 py-1 rounded-full mb-3 w-fit">
                  {featuredPost.data.category}
                </span>
              )}
              <h3 class="text-xl font-bold text-gray-900 leading-snug mb-3 group-hover:text-primary-600 transition-colors">
                {featuredPost.data.title}
              </h3>
              <p class="text-sm text-gray-500 leading-relaxed line-clamp-3">
                {featuredPost.data.description}
              </p>
              <span class="mt-4 text-sm text-primary-600 font-medium flex items-center gap-1">
                続きを読む
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </span>
            </div>
          </div>
        </a>
      </section>
    )}

    <!-- カテゴリ別セクション -->
    {categories.map(cat => {
      const c = colorMap[cat.color];
      return (
        <section>
          <div class="flex items-center justify-between mb-4">
            <h2 class={`text-lg font-bold flex items-center gap-2 ${c.text}`}>
              <span class="text-2xl">{cat.icon}</span>
              {cat.label}
              <span class="text-xs font-normal text-gray-400 ml-1">{cat.desc}</span>
            </h2>
            <a href={`/category/${cat.slug}`}
              class={`text-xs font-semibold px-3 py-1.5 rounded-full text-white ${c.btn} transition-colors`}>
              もっと見る →
            </a>
          </div>

          {cat.posts.length > 0 ? (
            <div class="grid sm:grid-cols-2 gap-4">
              {cat.posts.map(post => (
                <ArticleCard
                  title={post.data.title}
                  description={post.data.description ?? ''}
                  pubDate={post.data.pubDate}
                  slug={post.slug}
                  heroImage={post.data.heroImage}
                  category={post.data.category}
                  tags={post.data.tags}
                />
              ))}
            </div>
          ) : (
            <div class={`rounded-xl border ${c.border} ${c.bg} py-10 text-center ${c.text} text-sm`}>
              <div class="text-3xl mb-2">{cat.icon}</div>
              近日公開予定です
            </div>
          )}
        </section>
      );
    })}

    <!-- 新着記事一覧 -->
    <section>
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-bold text-gray-900 flex items-center gap-2">
          <span class="w-1 h-5 bg-primary-500 rounded-full inline-block"></span>
          新着記事
        </h2>
        <a href="/posts" class="text-sm text-primary-600 hover:text-primary-800 font-medium flex items-center gap-1">
          すべて見る
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {latestPosts.map(post => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description ?? ''}
            pubDate={post.data.pubDate}
            slug={post.slug}
            heroImage={post.data.heroImage}
            category={post.data.category}
            tags={post.data.tags}
          />
        ))}
      </div>
    </section>

    <!-- 筆者プロフィール -->
    <section>
      <h2 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
        <span class="w-1 h-5 bg-purple-500 rounded-full inline-block"></span>
        このブログを書いている人
      </h2>
      <div class="bg-white rounded-2xl shadow-md overflow-hidden">
        <div class="bg-gradient-to-r from-primary-700 to-primary-900 px-6 py-5 sm:flex sm:items-center sm:gap-5">
          <div class="w-20 h-20 rounded-full bg-white/20 border-4 border-white/40 flex items-center justify-center text-4xl flex-shrink-0 mx-auto sm:mx-0 mb-3 sm:mb-0">
            🛵
          </div>
          <div class="text-center sm:text-left">
            <h3 class="text-xl font-bold text-white">ひろ</h3>
            <p class="text-primary-200 text-xs mt-1">名古屋大学大学院 理学研究科 / 原付Uber配達員 / 簿記2級</p>
            <div class="flex flex-wrap justify-center sm:justify-start gap-1.5 mt-2">
              <span class="bg-white/15 text-white text-xs px-2.5 py-0.5 rounded-full">🎓 名大院生</span>
              <span class="bg-white/15 text-white text-xs px-2.5 py-0.5 rounded-full">💰 時給¥2,000</span>
              <span class="bg-white/15 text-white text-xs px-2.5 py-0.5 rounded-full">📖 簿記1級勉強中</span>
            </div>
          </div>
        </div>
        <div class="p-6 space-y-4 text-sm text-gray-700 leading-relaxed">
          <p>
            大学時代、飲食店のバイトで<strong>時給1,000円</strong>で5時間働いて、ヘトヘトになって手元に残るのは5,000円。交通費を引いたら4,000円ちょっと。「頑張ってるのに全然お金が貯まらない」という状況がずっと続いていました。
          </p>
          <p>
            そんなとき友達に勧められてUber Eatsを始めてみたら、世界が変わりました。原付で配達すると<strong>時給2,000円</strong>。しかもシフトなし、好きな時間に好きなだけ。飲食バイトで疲れ果てていたのが嘘みたいに、<strong>体力的にもめちゃくちゃ楽</strong>でした。原付に乗って音楽聴きながら配達するだけなので。
          </p>
          <p>
            さらに「現金受け取り×クレカ」で<strong>ポイントが自動で貯まるハック</strong>を発見してからは、ただ配達するだけで三井住友ゴールドカードの100万修行も達成できると気づきました。
          </p>
          <p>
            このブログでは、僕と同じように<strong>「もっと効率よく稼ぎたい」「バイトがしんどい」</strong>と思っている大学生に向けて、自分が実際に調べて・試して・うまくいった方法だけを書いています。
          </p>
          <div class="bg-gray-50 rounded-xl p-4 mt-2">
            <p class="font-bold text-gray-800 text-xs mb-2">ひろのスペック</p>
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 text-center">
              <div>
                <div class="text-lg">🛵</div>
                <div class="text-xs text-gray-500">原付Uber</div>
                <div class="text-xs font-bold text-gray-800">時給¥2,000</div>
              </div>
              <div>
                <div class="text-lg">📖</div>
                <div class="text-xs text-gray-500">資格</div>
                <div class="text-xs font-bold text-gray-800">簿記2級（1ヶ月）</div>
              </div>
              <div>
                <div class="text-lg">🎯</div>
                <div class="text-xs text-gray-500">目標</div>
                <div class="text-xs font-bold text-gray-800">簿記1級 / 会計士</div>
              </div>
              <div>
                <div class="text-lg">💳</div>
                <div class="text-xs text-gray-500">修行中</div>
                <div class="text-xs font-bold text-gray-800">三井住友ゴールドNL</div>
              </div>
            </div>
          </div>
          <div class="text-center pt-2">
            <a href="/about" class="inline-flex items-center gap-1 text-primary-600 text-sm font-medium hover:text-primary-800 transition-colors">
              もっと詳しく見る
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>
