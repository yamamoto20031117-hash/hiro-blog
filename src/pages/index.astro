---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import Thumb from '@/components/Thumb.astro';
import { getCollection } from 'astro:content';
import { SITE_NAME, SITE_TAGLINE, CATEGORIES, COLOR_MAP, getCategoryByLabel } from '@/site';
import { PRODUCTS, getProductImage } from '@/data/products';

const pickupProducts = PRODUCTS.slice(0, 4);

const allPosts = (await getCollection('posts'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const latestPosts = allPosts.slice(0, 6);
const featuredPost = allPosts.find(p => p.data.featured) ?? allPosts[0];

// 人気の比較ランキング（高成約ページを前面化）
const compareRankings = allPosts
  .filter(p => p.data.category === 'ガジェット' && (p.data.tags ?? []).some(t => t.includes('ランキング')))
  .slice(0, 4);

// ガジェット特化: ホームで前面に出すコアカテゴリのみ（他は残すがトップでは推さない）
const CORE_CATEGORY_SLUGS = ['gadget', 'home'];
const categorySections = CATEGORIES
  .filter(cat => CORE_CATEGORY_SLUGS.includes(cat.slug))
  .map(cat => ({
    cat,
    posts: allPosts.filter(p => p.data.category === cat.label).slice(0, 3),
  }))
  .filter(s => s.posts.length > 0);
---

<BaseLayout title={`${SITE_NAME}｜${SITE_TAGLINE}`}>

  <!-- ヒーロー -->
  <section class="bg-gradient-to-br from-primary-700 to-primary-900 text-white py-14 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-primary-200 text-xs font-semibold tracking-widest mb-3">実レビュー × ランキング × 徹底比較</p>
      <h1 class="text-2xl sm:text-4xl font-bold mb-4 leading-tight">
        {SITE_TAGLINE}
      </h1>
      <p class="text-primary-100 text-sm sm:text-base max-w-xl mx-auto leading-relaxed mb-7">
        イヤホン・モバイルバッテリー・充電器・スマート家電から一人暮らし家電まで。
        <br class="hidden sm:block" />いま買うべきガジェット・家電を、実レビューと比較で「失敗しない1つ」に絞り込みます。
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/ranking"
          class="bg-accent-500 hover:bg-accent-600 text-white text-sm font-bold px-6 py-3 rounded-full transition-colors shadow">
          🔥 売れ筋ランキングを見る
        </a>
        <a href="/products"
          class="bg-white/15 hover:bg-white/25 text-white text-sm font-bold px-6 py-3 rounded-full transition-colors border border-white/30">
          📝 商品レビューを見る
        </a>
      </div>
    </div>
  </section>

  <div class="max-w-5xl mx-auto px-4 py-10 space-y-14">

    <!-- カテゴリ入口 -->
    <section>
      <div class="grid grid-cols-2 gap-3">
        {CATEGORIES.slice(0, 2).map(cat => {
          const c = COLOR_MAP[cat.color] ?? COLOR_MAP['blue'];
          return (
            <a href={`/category/${cat.slug}`}
              class={`flex flex-col items-center gap-1 ${c.bg} ${c.text} border ${c.border} px-2 py-4 rounded-2xl font-semibold text-sm text-center hover:shadow-sm transition-shadow`}>
              <span class="text-2xl">{cat.icon}</span>
              {cat.label}
            </a>
          );
        })}
      </div>
    </section>

    <!-- 人気の比較ランキング -->
    {compareRankings.length > 0 && (
      <section>
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold text-gray-900 flex items-center gap-2">
            <span class="text-2xl">🔥</span>人気の比較ランキング
          </h2>
          <a href="/ranking" class="text-xs font-semibold px-3 py-1.5 rounded-full text-white bg-accent-500 hover:bg-accent-600 transition-colors">
            すべて見る →
          </a>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {compareRankings.map(post => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description ?? ''}
              pubDate={post.data.pubDate}
              slug={post.slug}
              heroImage={post.data.heroImage}
              category={post.data.category}
              tags={post.data.tags}
            />
          ))}
        </div>
      </section>
    )}

    <!-- 注目記事 -->
    {featuredPost && (
      <section>
        <h2 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
          <span class="w-1 h-5 bg-accent-500 rounded-full inline-block"></span>
          注目記事
        </h2>
        <a href={`/posts/${featuredPost.slug}`}
          class="block bg-white rounded-2xl shadow-md hover:shadow-lg transition-shadow overflow-hidden group">
          <div class="sm:flex">
            <div class="sm:w-2/5 h-48 sm:h-auto flex-shrink-0 overflow-hidden">
              {featuredPost.data.heroImage ? (
                <img src={featuredPost.data.heroImage} alt={featuredPost.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
              ) : (
                <div class="w-full h-full bg-gradient-to-br from-primary-100 to-primary-200 flex items-center justify-center text-6xl">🛒</div>
              )}
            </div>
            <div class="p-6 flex flex-col justify-center">
              {featuredPost.data.category && (
                <span class="inline-block bg-primary-100 text-primary-700 text-xs font-semibold px-3 py-1 rounded-full mb-3 w-fit">
                  {featuredPost.data.category}
                </span>
              )}
              <h3 class="text-xl font-bold text-gray-900 leading-snug mb-3 group-hover:text-primary-600 transition-colors">
                {featuredPost.data.title}
              </h3>
              <p class="text-sm text-gray-500 leading-relaxed line-clamp-3">{featuredPost.data.description}</p>
              <span class="mt-4 text-sm text-primary-600 font-medium flex items-center gap-1">続きを読む →</span>
            </div>
          </div>
        </a>
      </section>
    )}

    <!-- 注目の商品レビュー -->
    <section>
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-bold text-gray-900 flex items-center gap-2">
          <span class="text-2xl">📝</span>注目の商品レビュー
        </h2>
        <a href="/products" class="text-xs font-semibold px-3 py-1.5 rounded-full text-white bg-accent-500 hover:bg-accent-600 transition-colors">
          すべて見る →
        </a>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        {pickupProducts.map(p => {
          const pc = getCategoryByLabel(p.category);
          return (
            <a href={`/products/${p.slug}`} class="flex bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow overflow-hidden group">
              <div class="w-24 flex-shrink-0">
                <Thumb image={getProductImage(p.asin)} emoji={p.emoji} color={pc?.color ?? 'blue'} alt={p.name} class="w-full h-full min-h-[6rem]" />
              </div>
              <div class="p-4 min-w-0 flex flex-col">
                <h3 class="font-bold text-gray-900 text-sm leading-snug group-hover:text-primary-600 transition-colors line-clamp-2">{p.name}</h3>
                <p class="text-xs text-accent-600 font-semibold mt-1 line-clamp-1">{p.tagline}</p>
                <div class="mt-auto pt-2 flex items-center justify-between">
                  <span class="text-yellow-400 text-xs">{'★'.repeat(Math.round(p.rating))}<span class="text-gray-500 ml-1">{p.rating.toFixed(1)}</span></span>
                  <span class="text-sm font-bold text-primary-700">{p.price}</span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </section>

    <!-- カテゴリ別（記事があるものだけ） -->
    {categorySections.map(({ cat, posts }) => {
      const c = COLOR_MAP[cat.color] ?? COLOR_MAP['blue'];
      return (
        <section>
          <div class="flex items-center justify-between mb-4">
            <h2 class={`text-lg font-bold flex items-center gap-2 ${c.text}`}>
              <span class="text-2xl">{cat.icon}</span>
              {cat.label}
              <span class="text-xs font-normal text-gray-400 ml-1">{cat.desc}</span>
            </h2>
            <a href={`/category/${cat.slug}`}
              class={`text-xs font-semibold px-3 py-1.5 rounded-full text-white ${c.btn} transition-colors whitespace-nowrap`}>
              もっと見る →
            </a>
          </div>
          <div class="grid sm:grid-cols-2 gap-4">
            {posts.map(post => (
              <ArticleCard
                title={post.data.title}
                description={post.data.description ?? ''}
                pubDate={post.data.pubDate}
                slug={post.slug}
                heroImage={post.data.heroImage}
                category={post.data.category}
                tags={post.data.tags}
              />
            ))}
          </div>
        </section>
      );
    })}

    <!-- 新着記事 -->
    <section>
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-bold text-gray-900 flex items-center gap-2">
          <span class="w-1 h-5 bg-primary-500 rounded-full inline-block"></span>
          新着記事
        </h2>
        <a href="/posts" class="text-sm text-primary-600 hover:text-primary-800 font-medium flex items-center gap-1">すべて見る →</a>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {latestPosts.map(post => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description ?? ''}
            pubDate={post.data.pubDate}
            slug={post.slug}
            heroImage={post.data.heroImage}
            category={post.data.category}
            tags={post.data.tags}
          />
        ))}
      </div>
    </section>

  </div>
</BaseLayout>
