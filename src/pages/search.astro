---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE_NAME, CATEGORIES } from '@/site';
const suggestCats = CATEGORIES.slice(0, 4);
---

<BaseLayout title={`サイト内検索｜${SITE_NAME}`} description={`${SITE_NAME}のサイト内検索。記事と商品レビューをキーワードで探せます。`} noindex={true}>
  <div class="max-w-2xl mx-auto px-4 py-10">
    <h1 class="text-xl font-bold text-gray-900 mb-4">サイト内検索</h1>

    <form id="search-form" class="flex gap-2 mb-6" role="search">
      <input
        id="q" name="q" type="search" autocomplete="off"
        placeholder="キーワードで探す（例：イヤホン、Anker、ケトル）"
        class="flex-1 rounded-xl border border-gray-300 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary-400"
        aria-label="検索キーワード"
      />
      <button type="submit" class="bg-primary-600 hover:bg-primary-700 text-white font-bold text-sm px-5 rounded-xl transition-colors">検索</button>
    </form>

    <p id="search-status" class="text-sm text-gray-500 mb-4"></p>
    <div id="search-results" class="space-y-3"></div>

    <div id="search-empty" class="hidden">
      <p class="text-sm text-gray-600 mb-3">お探しの結果が見つかりませんでした。カテゴリから探してみてください。</p>
      <div class="grid grid-cols-2 gap-3">
        {suggestCats.map((c) => (
          <a href={`/category/${c.slug}`} class="flex items-center gap-2 rounded-xl border border-gray-200 bg-white px-4 py-3 text-sm font-semibold text-gray-800 hover:shadow-sm transition-shadow">
            <span class="text-xl">{c.icon}</span>{c.label}
          </a>
        ))}
      </div>
    </div>
  </div>

  <script>
    type Item = { type: string; title: string; desc: string; url: string; category: string; tags: string };
    const form = document.getElementById('search-form') as HTMLFormElement;
    const input = document.getElementById('q') as HTMLInputElement;
    const status = document.getElementById('search-status')!;
    const results = document.getElementById('search-results')!;
    const empty = document.getElementById('search-empty')!;
    let index: Item[] | null = null;

    const esc = (s: string) => s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!));

    async function ensureIndex() {
      if (index) return index;
      const res = await fetch('/search-index.json');
      index = (await res.json()) as Item[];
      return index;
    }

    function render(items: Item[], q: string) {
      results.innerHTML = items.map((it) => `
        <a href="${it.url}" class="block rounded-xl border border-gray-100 bg-white p-4 shadow-sm hover:shadow-md transition-shadow">
          <div class="flex items-center gap-2 mb-1">
            <span class="text-[10px] font-bold text-white bg-primary-500 px-1.5 py-0.5 rounded">${esc(it.type)}</span>
            ${it.category ? `<span class="text-[11px] text-gray-400">${esc(it.category)}</span>` : ''}
          </div>
          <div class="font-bold text-gray-900 text-sm leading-snug">${esc(it.title)}</div>
          <div class="text-xs text-gray-500 mt-1 line-clamp-2">${esc(it.desc)}</div>
        </a>`).join('');
      empty.classList.toggle('hidden', items.length > 0);
      status.textContent = items.length > 0 ? `「${q}」の検索結果：${items.length}件` : `「${q}」に一致する結果はありませんでした`;
    }

    async function search(q: string) {
      q = q.trim();
      if (!q) { results.innerHTML = ''; empty.classList.add('hidden'); status.textContent = ''; return; }
      const idx = await ensureIndex();
      const terms = q.toLowerCase().split(/\s+/);
      const hits = idx.filter((it) => {
        const hay = `${it.title} ${it.desc} ${it.category} ${it.tags}`.toLowerCase();
        return terms.every((t) => hay.includes(t));
      });
      render(hits, q);
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const q = input.value;
      history.replaceState(null, '', q ? `/search?q=${encodeURIComponent(q)}` : '/search');
      search(q);
    });

    // URLの ?q= で初期検索
    const params = new URLSearchParams(location.search);
    const initial = params.get('q') || '';
    if (initial) { input.value = initial; search(initial); }
    input.focus();
  </script>
</BaseLayout>
