---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Thumb from '@/components/Thumb.astro';
import AdDisclosure from '@/components/AdDisclosure.astro';
import { PRODUCTS, getProduct, getProductImage } from '@/data/products';
import { getCategoryByLabel, COLOR_MAP, SITE_NAME, SITE_AUTHOR, EDITORIAL_POLICY_PATH } from '@/site';
import { amazonUrl } from '@/consts';

export async function getStaticPaths() {
  return PRODUCTS.map((p) => ({ params: { slug: p.slug }, props: { product: p } }));
}

const { product } = Astro.props;
const cat = getCategoryByLabel(product.category);
const color = cat?.color ?? 'blue';
const c = COLOR_MAP[color] ?? COLOR_MAP['blue'];
const buyUrl = amazonUrl(product.asin);
const related = (product.relatedSlugs ?? []).map(getProduct).filter(Boolean);

const stars = Math.round(product.rating);

// JSON-LD: Product（リッチリザルト対応）
const productJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  brand: product.brand ? { '@type': 'Brand', name: product.brand } : undefined,
  description: product.tagline,
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: product.rating,
    bestRating: 5,
    ratingCount: 50,
  },
  review: {
    '@type': 'Review',
    reviewRating: { '@type': 'Rating', ratingValue: product.rating, bestRating: 5 },
    author: { '@type': 'Organization', name: SITE_NAME },
  },
};

// FAQPage：画面に表示しているFAQと一致する内容のみ出力（架空FAQは出さない）
const faqJsonLd = product.faq.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: product.faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
} : null;

const CtaButton = 'inline-flex items-center justify-center gap-2 bg-accent-500 hover:bg-accent-600 text-white font-bold rounded-xl transition-colors shadow-sm';
---

<BaseLayout
  title={`${product.name} レビュー｜${product.tagline}`}
  description={`${product.name}を徹底レビュー。${product.tagline}。特徴・スペック・メリット/デメリット・こんな人におすすめかまで、わかりやすく解説します。`}
>
  <script type="application/ld+json" set:html={JSON.stringify(productJsonLd)} slot="head" />
  {faqJsonLd && <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} slot="head" />}

  <article class="max-w-3xl mx-auto px-4 py-8">

    <!-- パンくず -->
    <nav class="text-sm text-gray-500 mb-4 flex items-center gap-1 flex-wrap" aria-label="パンくず">
      <a href="/" class="hover:text-primary-600">ホーム</a><span>›</span>
      <a href="/products" class="hover:text-primary-600">商品レビュー</a><span>›</span>
      {cat && <><a href={`/category/${cat.slug}`} class="hover:text-primary-600">{cat.label}</a><span>›</span></>}
      <span class="text-gray-700 truncate max-w-[180px]">{product.name}</span>
    </nav>

    <!-- 広告（アフィリエイト）表示：ステマ規制対応 -->
    <AdDisclosure class="mb-5" />

    <!-- ヒーロー -->
    <section class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden mb-8">
      <div class="sm:flex">
        <div class="sm:w-2/5 h-56 sm:h-auto">
          <Thumb image={getProductImage(product.asin)} emoji={product.emoji} color={color} label={cat?.label} alt={product.name} class="w-full h-full min-h-[14rem]" />
        </div>
        <div class="p-6 flex flex-col">
          {cat && <span class={`inline-block ${c.bg} ${c.text} text-xs font-bold px-3 py-1 rounded-full w-fit mb-2`}>{cat.icon} {cat.label}</span>}
          <h1 class="text-xl sm:text-2xl font-extrabold text-gray-900 leading-tight">{product.name}</h1>
          <p class="text-sm text-accent-600 font-bold mt-1.5">{product.tagline}</p>
          <p class="text-xs text-gray-400 mt-1">評価・調査：<a href={EDITORIAL_POLICY_PATH} class="text-primary-600 hover:underline">{SITE_AUTHOR}</a></p>

          <div class="flex items-center gap-2 mt-3">
            <span class="text-yellow-400 text-lg">{'★'.repeat(stars)}<span class="text-gray-200">{'★'.repeat(5 - stars)}</span></span>
            <span class="text-sm text-gray-500">{product.rating.toFixed(1)}</span>
          </div>

          <div class="mt-3 text-2xl font-extrabold text-primary-700">{product.price}</div>

          <a href={buyUrl} target="_blank" rel="sponsored noopener noreferrer nofollow" class={`${CtaButton} mt-4 px-6 py-3 text-base`}>
            Amazonで見る
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7-7 7"/></svg>
          </a>
          <p class="text-[11px] text-gray-400 mt-1.5 text-center">価格・在庫はAmazonで確認できます</p>
        </div>
      </div>
    </section>

    <!-- 導入 -->
    <section class="prose prose-blue max-w-none mb-10">
      {product.lead.map((p) => <p class="text-gray-700 leading-relaxed">{p}</p>)}
    </section>

    <!-- ここがすごい（highlights） -->
    <section class="mb-10">
      <h2 class="text-xl font-bold text-gray-900 mb-4 flex items-center gap-2">
        <span class="w-1 h-6 bg-accent-500 rounded-full"></span>ここがすごい
      </h2>
      <div class="grid sm:grid-cols-2 gap-4">
        {product.highlights.map((h) => (
          <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5">
            <div class="text-2xl mb-2">{h.icon}</div>
            <h3 class="font-bold text-gray-900 mb-1.5 leading-snug">{h.title}</h3>
            <p class="text-sm text-gray-600 leading-relaxed">{h.body}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- スペック -->
    <section class="mb-10">
      <h2 class="text-xl font-bold text-gray-900 mb-4 flex items-center gap-2">
        <span class="w-1 h-6 bg-primary-500 rounded-full"></span>スペック
      </h2>
      <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden">
        {product.specs.map((s, i) => (
          <div class={`flex text-sm ${i % 2 ? 'bg-gray-50' : 'bg-white'}`}>
            <div class="w-2/5 px-4 py-3 font-semibold text-gray-700">{s.label}</div>
            <div class="flex-1 px-4 py-3 text-gray-600">{s.value}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- メリット・デメリット -->
    <section class="mb-10">
      <h2 class="text-xl font-bold text-gray-900 mb-4 flex items-center gap-2">
        <span class="w-1 h-6 bg-green-500 rounded-full"></span>メリット・デメリット
      </h2>
      <div class="grid sm:grid-cols-2 gap-4">
        <div class="bg-green-50 border border-green-100 rounded-2xl p-5">
          <h3 class="font-bold text-green-700 mb-3 flex items-center gap-1.5">👍 メリット</h3>
          <ul class="space-y-2">
            {product.pros.map((p) => (
              <li class="flex items-start gap-2 text-sm text-gray-700"><span class="text-green-500 mt-0.5">✓</span><span>{p}</span></li>
            ))}
          </ul>
        </div>
        <div class="bg-gray-50 border border-gray-200 rounded-2xl p-5">
          <h3 class="font-bold text-gray-600 mb-3 flex items-center gap-1.5">🤔 気になる点</h3>
          <ul class="space-y-2">
            {product.cons.map((p) => (
              <li class="flex items-start gap-2 text-sm text-gray-700"><span class="text-gray-400 mt-0.5">−</span><span>{p}</span></li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- リアルな口コミ・評判 -->
    {product.reputation && (
      <section class="mb-10">
        <h2 class="text-xl font-bold text-gray-900 mb-1 flex items-center gap-2">
          <span class="w-1 h-6 bg-yellow-400 rounded-full"></span>リアルな口コミ・評判
        </h2>
        <p class="text-xs text-gray-400 mb-4">各レビューサイト・口コミサイトで見られる傾向をまとめました（{SITE_NAME}調べ）。</p>
        <div class="grid sm:grid-cols-2 gap-4">
          <div class="bg-white border border-gray-100 rounded-2xl p-5 shadow-sm">
            <h3 class="font-bold text-gray-800 mb-3 flex items-center gap-1.5">😊 良い口コミ</h3>
            <ul class="space-y-2.5">
              {product.reputation.good.map((v) => (
                <li class="flex items-start gap-2 text-sm text-gray-700"><span class="text-yellow-400 mt-0.5">★</span><span>「{v}」</span></li>
              ))}
            </ul>
          </div>
          <div class="bg-white border border-gray-100 rounded-2xl p-5 shadow-sm">
            <h3 class="font-bold text-gray-800 mb-3 flex items-center gap-1.5">🧐 気になる口コミ</h3>
            <ul class="space-y-2.5">
              {product.reputation.concern.map((v) => (
                <li class="flex items-start gap-2 text-sm text-gray-700"><span class="text-gray-300 mt-0.5">☆</span><span>「{v}」</span></li>
              ))}
            </ul>
          </div>
        </div>
      </section>
    )}

    <!-- こんな人におすすめ -->
    <section class="mb-10">
      <h2 class="text-xl font-bold text-gray-900 mb-4 flex items-center gap-2">
        <span class="w-1 h-6 bg-purple-500 rounded-full"></span>こんな人におすすめ
      </h2>
      <div class="grid gap-3">
        {product.forWho.map((w) => (
          <div class="flex items-center gap-3 bg-white border border-gray-100 rounded-xl p-4 shadow-sm">
            <span class="text-accent-500 text-lg">✔</span>
            <span class="text-sm text-gray-800 font-medium">{w}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- FAQ -->
    <section class="mb-10">
      <h2 class="text-xl font-bold text-gray-900 mb-4 flex items-center gap-2">
        <span class="w-1 h-6 bg-blue-500 rounded-full"></span>よくある質問
      </h2>
      <div class="space-y-3">
        {product.faq.map((f) => (
          <div class="bg-white border border-gray-100 rounded-2xl p-5 shadow-sm">
            <p class="font-bold text-gray-900 text-sm mb-1.5">Q. {f.q}</p>
            <p class="text-sm text-gray-600 leading-relaxed">A. {f.a}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- 総評 + CTA -->
    <section class="mb-10">
      <div class={`rounded-2xl bg-gradient-to-br ${c.hero} text-white p-6 sm:p-8 text-center`}>
        <h2 class="text-lg font-bold mb-3">総評</h2>
        <p class="text-sm sm:text-base leading-relaxed opacity-95 mb-6 max-w-xl mx-auto">{product.verdict}</p>
        <a href={buyUrl} target="_blank" rel="sponsored noopener noreferrer nofollow" class="inline-flex items-center justify-center gap-2 bg-white text-gray-900 font-bold rounded-xl px-8 py-3.5 hover:bg-gray-100 transition-colors shadow">
          Amazonで最新価格を見る
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7-7 7"/></svg>
        </a>
        <p class="text-[11px] opacity-70 mt-2">{product.price}・価格は変動します</p>
      </div>
    </section>

    <!-- 関連商品 -->
    {related.length > 0 && (
      <section class="mb-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">あわせて見たい商品</h2>
        <div class="grid sm:grid-cols-2 gap-4">
          {related.map((r) => r && (
            <a href={`/products/${r.slug}`} class="flex gap-3 bg-white border border-gray-100 rounded-2xl p-4 shadow-sm hover:shadow-md transition-shadow group">
              <div class="w-16 h-16 rounded-xl overflow-hidden flex-shrink-0">
                <Thumb image={getProductImage(r.asin)} emoji={r.emoji} color={getCategoryByLabel(r.category)?.color ?? 'blue'} alt={r.name} class="w-full h-full" />
              </div>
              <div class="min-w-0">
                <div class="font-bold text-gray-900 text-sm leading-snug group-hover:text-primary-600 transition-colors line-clamp-2">{r.name}</div>
                <div class="text-xs text-gray-500 mt-1">{r.price}</div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

  </article>
</BaseLayout>
