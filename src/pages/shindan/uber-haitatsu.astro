---
import BaseLayout from '@/layouts/BaseLayout.astro';
import DiagnosisQuiz from '@/components/DiagnosisQuiz.astro';
import ComparisonTable from '@/components/ComparisonTable.astro';
import { amazonSearch, amazonUrl } from '@/consts';

// ★リンクの差し替え方★
//   暫定リンクは amazonSearch('キーワード')（=検索結果に飛ぶ）。
//   実際の商品が決まったら import に amazonUrl を足して amazonUrl('ASIN') に置き換えてください。
//   例）url: amazonUrl('B08XXXXXXX')

const questions = [
  {
    question: '主な移動手段は？',
    options: [
      { label: '🚲 自転車', scores: { comfort: 1, starter: 1 } },
      { label: '🛵 原付・バイク', scores: { power: 1 } },
      { label: '🚶 徒歩・電車メイン', scores: { starter: 1 } },
    ],
  },
  {
    question: 'よく稼働する時間帯・天気は？',
    options: [
      { label: '☀️ 昼メインでがっつり', scores: { power: 1 } },
      { label: '🌙 夜メイン', scores: { starter: 1 } },
      { label: '🌧️ 雨の日も止まらず稼働', scores: { rain: 2 } },
    ],
  },
  {
    question: '配達中の一番の悩みは？',
    options: [
      { label: '🔋 スマホの電池・ナビ', scores: { starter: 1, power: 1 } },
      { label: '🍜 料理の崩れ・冷め', scores: { comfort: 1 } },
      { label: '💪 体の疲れ・重さ', scores: { comfort: 2 } },
      { label: '🥵 暑さ・寒さ', scores: { rain: 1, comfort: 1 } },
    ],
  },
  {
    question: '配達の頻度は？',
    options: [
      { label: '🔥 ほぼ毎日がっつり', scores: { power: 2 } },
      { label: '📅 週末・すきま時間', scores: { starter: 1 } },
      { label: '🌱 まずはお試し', scores: { starter: 2 } },
    ],
  },
];

const results = [
  {
    id: 'starter',
    title: 'これから始める人の必需品タイプ',
    lead: 'まずはこの3つ。配達員の85%以上が使うスマホホルダーとモバイルバッテリーから揃えれば、初日から失敗しません。',
    products: [
      { name: 'スマホホルダー（自転車・バイク兼用）', description: 'リクエストとナビをスマホを出さずに確認でき、効率が段違いに。まず最初に買うべき1つ。', price: '¥1,480〜', url: amazonSearch('自転車 バイク スマホホルダー 防水 防振'), badge: '最初の1つ', rating: 4.5, stat: '配達員の使用率85.7%（No.1）' },
      { name: 'Anker PowerCore 10000（モバイルバッテリー）', description: 'ナビ＋アプリで電池は一気に減る。Amazon定番ベストセラーの軽量10000mAh。1日稼働の必需品。', price: '¥3,990〜', url: amazonUrl('B019GNUT0C'), rating: 4.5, stat: '配達員の77.4%が携帯' },
      { name: '保温保冷デリバリーバッグ（標準サイズ）', description: 'まずは標準サイズで十分。保温保冷でクレーム（冷め・崩れ）を防ぐ。', price: '¥3,180〜', url: amazonSearch('デリバリーバッグ 保温 保冷 出前'), rating: 4.3 },
    ],
  },
  {
    id: 'power',
    title: 'がっつり稼ぐ本格装備タイプ',
    lead: '毎日稼働でこそ差が出る装備。大容量バッグ＋積載強化で、1件あたりの疲労と時間ロスを削ります。',
    products: [
      { name: '大容量デリバリーバッグ（拡張タイプ）', description: 'ピザ・大型注文も一発。仕切り付きで積み替えが速く、回転数が上がる。', price: '¥4,980〜', url: amazonSearch('デリバリーバッグ 大容量 拡張'), badge: '本格派イチオシ', rating: 4.5 },
      { name: 'バイク用防振スマホホルダー', description: '原付の振動でカメラ・ナビが乱れるのを防ぐ防振タイプ。長時間でも安定。', price: '¥2,680〜', url: amazonSearch('バイク スマホホルダー 防振'), rating: 4.4 },
      { name: '自転車用リアキャリア', description: '重いバッグを肩でなく車体で支える。腰・肩の消耗を大幅カット。', price: '¥3,480〜', url: amazonSearch('自転車 リアキャリア 荷台'), rating: 4.2 },
    ],
  },
  {
    id: 'rain',
    title: '雨天・悪天候に強いタイプ',
    lead: '雨の日は単価が上がるチャンス。装備さえ整えれば「稼げる日」に変わります。',
    products: [
      { name: '自転車・バイク用レインウェア上下', description: '蒸れにくい透湿タイプが快適。動きやすさで配達効率が落ちない。', price: '¥3,980〜', url: amazonSearch('レインウェア 上下 自転車 透湿'), badge: '雨の日の主役', rating: 4.3 },
      { name: 'デリバリーバッグ用 防水カバー', description: 'バッグと料理を雨から守る。中の紙袋がふやける事故を防止。', price: '¥1,680〜', url: amazonSearch('デリバリーバッグ 防水カバー'), rating: 4.1 },
      { name: 'ハンドルカバー（防寒・防風）', description: '冬の手のかじかみ対策に。ブレーキ操作の安全性も上がる。', price: '¥1,380〜', url: amazonSearch('自転車 ハンドルカバー 防寒'), rating: 4.2 },
    ],
  },
  {
    id: 'comfort',
    title: '疲れにくさ・料理保護重視タイプ',
    lead: '長く続けるカギは「疲れない」「こぼさない」。体と料理を守る装備で、安定して稼ぎ続けられます。',
    products: [
      { name: 'デリバリーバッグ用 緩衝インナー', description: '段差の衝撃から料理を守り、崩れ・こぼれを防ぐ。低評価の最大原因をつぶす1品。', price: '¥1,780〜', url: amazonSearch('デリバリーバッグ 緩衝材 仕切り インナー'), badge: '崩れ防止に', rating: 4.4, stat: '配達員の60.7%が使用' },
      { name: '保冷インナーバッグ', description: '夏場のドリンク・アイス・生ものの温度をキープ。低評価の原因を1つ消す。', price: '¥1,980〜', url: amazonSearch('保冷バッグ インナー 大容量'), rating: 4.3 },
      { name: '低反発サドルカバー / クッション', description: '長時間の自転車稼働のお尻・腰の負担を軽減。地味だが効く1品。', price: '¥1,280〜', url: amazonSearch('自転車 サドルカバー 低反発'), rating: 4.1 },
    ],
  },
];

// ===== 徹底比較表（デリバリーバッグ＝一番の高単価・購入直前needs） =====
const bagHeaders = ['タイプ', '容量目安', '保温保冷', '背負い方'];
const bagItems = [
  { name: '標準デリバリーバッグ', url: amazonSearch('デリバリーバッグ 保温 保冷 標準'), price: '¥3,180〜', cells: ['エントリー', '約25L', '◯', '肩掛け/背負い'], rating: 4.3, badge: '初心者向け' },
  { name: '大容量・拡張バッグ', url: amazonSearch('デリバリーバッグ 大容量 拡張'), price: '¥4,980〜', cells: ['本格派', '約30〜45L', '◎', 'リュック型'], rating: 4.5, badge: 'イチオシ', highlight: true },
  { name: '折りたたみコンパクト', url: amazonSearch('デリバリーバッグ 折りたたみ コンパクト'), price: '¥2,480〜', cells: ['サブ/お試し', '約20L', '◯', '肩掛け'], rating: 4.0 },
];
---

<BaseLayout
  title="Uber Eats配達スタイル診断｜あなたに必要な装備が30秒でわかる"
  description="移動手段・稼働スタイルに合わせて、Uber Eats配達に本当に必要なグッズを診断。配達員の使用率データをもとに、初心者からがっつり派まで最適な装備を提案します。"
  keywords="Uber Eats,配達,グッズ,必需品,診断,デリバリーバッグ,スマホホルダー,おすすめ,大学生"
>
  <article class="max-w-2xl mx-auto px-4 py-10">

    <header class="mb-8 text-center">
      <span class="inline-block bg-accent-500 text-white text-xs font-bold px-3 py-1 rounded-full mb-3">30秒でわかる無料診断</span>
      <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 leading-tight mb-3">
        Uber Eats配達スタイル診断<br class="sm:hidden" />
        <span class="text-primary-700">あなたに必要な装備は？</span>
      </h1>
      <p class="text-gray-600 text-sm leading-relaxed">
        移動手段や稼ぎ方は人それぞれ。4つの質問に答えるだけで、<br class="hidden sm:block" />
        配達員の使用率データをもとに「本当に必要なグッズ」を提案します。
      </p>
    </header>

    <DiagnosisQuiz questions={questions} results={results} />

    <!-- 比較表セクション -->
    <section class="mt-14">
      <h2 class="text-xl font-bold text-gray-900 mb-1">デリバリーバッグ 徹底比較</h2>
      <p class="text-sm text-gray-600 mb-5">最初に迷うのがバッグ。稼働スタイル別に選び方をまとめました。</p>
      <ComparisonTable headers={bagHeaders} items={bagItems} />
    </section>

    <!-- 関連記事への導線（既存記事） -->
    <section class="mt-14 bg-primary-50 rounded-2xl p-6">
      <h2 class="text-lg font-bold text-gray-900 mb-3">📖 あわせて読みたい</h2>
      <ul class="space-y-2 text-sm">
        <li><a href="/posts/uber-eats-nagoya-gentsuki" class="text-primary-700 font-medium hover:underline">→ 原付でUber Eats配達｜名古屋で時給2000円の稼ぎ方</a></li>
        <li><a href="/posts/uber-fuyou-daigakusei" class="text-primary-700 font-medium hover:underline">→ 大学生の扶養と稼ぎすぎライン｜103万・130万の壁</a></li>
        <li><a href="/posts/uber-kakuteishinkoku-guide" class="text-primary-700 font-medium hover:underline">→ Uber配達の確定申告ガイド</a></li>
      </ul>
    </section>

  </article>
</BaseLayout>
