---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE_NAME, SITE_TAGLINE, CATEGORIES, COLOR_MAP } from '@/site';
const aboutCats = CATEGORIES.slice(0, 4);
---

<BaseLayout
  title={`このサイトについて｜${SITE_NAME}`}
  description={`${SITE_NAME}は、${SITE_TAGLINE}買い物ガイドです。売れ筋商品を診断・ランキング・徹底比較で紹介し、あなたに最適な「買い」を見つけるお手伝いをします。`}
>
  <!-- ヒーロー -->
  <section class="bg-gradient-to-br from-primary-700 to-primary-900 text-white py-12 px-4">
    <div class="max-w-2xl mx-auto text-center">
      <div class="w-20 h-20 rounded-2xl bg-white/15 border border-white/30 mx-auto mb-4 flex items-center justify-center text-4xl">🛒</div>
      <h1 class="text-2xl font-bold mb-2">このサイトについて</h1>
      <p class="text-primary-100 text-sm">{SITE_NAME} — {SITE_TAGLINE}</p>
    </div>
  </section>

  <div class="max-w-2xl mx-auto px-4 py-10 space-y-10">

    <!-- ミッション -->
    <section>
      <h2 class="text-xl font-bold text-gray-900 mb-4 flex items-center gap-2">
        <span class="w-1 h-6 bg-primary-500 rounded-full"></span>
        {SITE_NAME}とは
      </h2>
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 space-y-4 text-gray-700 leading-relaxed text-sm">
        <p>
          {SITE_NAME}は、<strong>「今どれが買い？」を診断とランキングで解決する</strong>買い物ガイドです。
          ガジェット・家電・生活雑貨から節約・副業に役立つアイテムまで、いま売れている商品を横断的に取り上げています。
        </p>
        <p>
          ネットには商品が多すぎて、「結局どれを選べばいいのか分からない」と迷ってしまいますよね。
          そこで当サイトでは、<strong>使用頻度・コスパ・失敗しにくさ</strong>という実用目線で商品を絞り込み、
          <strong>診断・ランキング・徹底比較</strong>という3つの切り口で「あなたに最適な1つ」までナビゲートします。
        </p>
      </div>
    </section>

    <!-- 編集方針 -->
    <section>
      <h2 class="text-xl font-bold text-gray-900 mb-4 flex items-center gap-2">
        <span class="w-1 h-6 bg-green-500 rounded-full"></span>
        商品の選び方（編集方針）
      </h2>
      <div class="grid gap-3">
        <div class="bg-gray-50 rounded-xl p-4">
          <div class="font-semibold text-gray-900 text-sm mb-1">① 毎日・毎シーズン使うか</div>
          <div class="text-xs text-gray-600 leading-relaxed">使用頻度が高いほど満足度は高くなります。「たまにしか使わない」ものより、生活に定着するものを優先して紹介します。</div>
        </div>
        <div class="bg-gray-50 rounded-xl p-4">
          <div class="font-semibold text-gray-900 text-sm mb-1">② 価格に対する満足度（コスパ）</div>
          <div class="text-xs text-gray-600 leading-relaxed">高いほど良いとは限りません。価格に見合った、あるいはそれ以上の価値がある商品を評価します。</div>
        </div>
        <div class="bg-gray-50 rounded-xl p-4">
          <div class="font-semibold text-gray-900 text-sm mb-1">③ 失敗しにくさ（定番・高評価）</div>
          <div class="text-xs text-gray-600 leading-relaxed">レビュー数・評価・売れ筋の実績を重視。多くの人に選ばれている定番は、それだけ失敗が少ない選択肢です。</div>
        </div>
      </div>
    </section>

    <!-- カテゴリ -->
    <section>
      <h2 class="text-xl font-bold text-gray-900 mb-4 flex items-center gap-2">
        <span class="w-1 h-6 bg-blue-500 rounded-full"></span>
        取り扱いカテゴリ
      </h2>
      <div class="grid grid-cols-2 gap-3">
        {aboutCats.map((cat) => {
          const c = COLOR_MAP[cat.color] ?? COLOR_MAP['blue'];
          return (
            <a href={`/category/${cat.slug}`} class={`flex gap-3 p-4 rounded-xl ${c.bg} border ${c.border} hover:shadow-sm transition-shadow no-underline`}>
              <div class="text-2xl flex-shrink-0">{cat.icon}</div>
              <div>
                <div class={`font-semibold text-sm ${c.text}`}>{cat.label}</div>
                <div class="text-xs text-gray-600 mt-0.5 leading-relaxed">{cat.desc}</div>
              </div>
            </a>
          );
        })}
      </div>
    </section>

    <!-- 免責 -->
    <section class="bg-gray-50 rounded-xl p-4">
      <h3 class="text-sm font-bold text-gray-700 mb-2">免責事項・広告について</h3>
      <ul class="text-xs text-gray-500 space-y-1 list-disc list-inside">
        <li>{SITE_NAME}は各種アフィリエイトプログラム（Amazonアソシエイト等）に参加しており、リンクから購入・お申し込みがあった場合に報酬が発生することがあります。</li>
        <li>報酬の有無は、掲載順位や評価に影響を与えません。</li>
        <li>価格・仕様・在庫は執筆時点のものです。最新情報は各リンク先の公式ページをご確認ください。</li>
      </ul>
      <p class="text-xs text-gray-400 mt-3">
        詳しくは <a href="/disclaimer" class="text-primary-600 hover:underline">免責事項</a> ・
        <a href="/privacy" class="text-primary-600 hover:underline">プライバシーポリシー</a> をご覧ください。
      </p>
    </section>

  </div>
</BaseLayout>
