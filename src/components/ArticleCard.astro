---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  heroImage?: string;
  category?: string;
  tags?: string[];
}

const { title, description, pubDate, slug, heroImage, category, tags = [] } = Astro.props;

const dateStr = pubDate.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

// カテゴリごとのデザイン設定
const categoryDesigns: Record<string, { gradient: string; emoji: string; accent: string }> = {
  'クレカ修行': {
    gradient: 'from-blue-800 via-blue-600 to-blue-500',
    emoji: '💳',
    accent: 'bg-amber-400 text-amber-900',
  },
  'Uber稼ぎ方': {
    gradient: 'from-emerald-800 via-emerald-600 to-emerald-400',
    emoji: '🛵',
    accent: 'bg-emerald-400 text-emerald-900',
  },
  '扶養・税金': {
    gradient: 'from-violet-800 via-violet-600 to-violet-400',
    emoji: '🛡️',
    accent: 'bg-violet-400 text-violet-900',
  },
};

const design = category && categoryDesigns[category]
  ? categoryDesigns[category]
  : { gradient: 'from-gray-700 via-gray-600 to-gray-500', emoji: '📝', accent: 'bg-gray-400 text-gray-900' };
---

<article class="bg-white rounded-xl shadow-sm hover:shadow-md transition-shadow overflow-hidden group">
  <a href={`/posts/${slug}`} class="block">
    <!-- サムネイル -->
    <div class="relative overflow-hidden bg-gray-100 h-44 sm:h-48">
      {heroImage ? (
        <img
          src={heroImage}
          alt={title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
          loading="lazy"
        />
      ) : (
        <div class={`w-full h-full bg-gradient-to-br ${design.gradient} flex items-center justify-content relative overflow-hidden group-hover:scale-105 transition-transform duration-300`}>
          <!-- 装飾円 -->
          <div class="absolute -right-8 -top-8 w-40 h-40 rounded-full bg-white opacity-5"></div>
          <div class="absolute right-20 bottom-0 w-24 h-24 rounded-full bg-white opacity-5"></div>
          <div class="absolute -left-6 -bottom-6 w-28 h-28 rounded-full bg-white opacity-5"></div>
          <!-- 大きな絵文字 -->
          <div class="absolute right-6 top-1/2 -translate-y-1/2 text-7xl opacity-20 select-none" aria-hidden="true">
            {design.emoji}
          </div>
          <!-- カテゴリテキスト -->
          <div class="relative z-10 p-6 flex flex-col justify-end h-full">
            <span class={`inline-block self-start ${design.accent} text-xs font-bold px-3 py-1 rounded-full mb-2 shadow-sm`}>
              {category || 'ブログ'}
            </span>
            <p class="text-white text-sm font-bold leading-snug line-clamp-2 drop-shadow-sm">
              {title}
            </p>
          </div>
        </div>
      )}

      {heroImage && category && (
        <span class="absolute top-3 left-3 bg-primary-600 text-white text-xs font-semibold px-2.5 py-1 rounded-full shadow">
          {category}
        </span>
      )}
    </div>

    <!-- コンテンツ -->
    <div class="p-4">
      <h2 class="font-bold text-gray-900 text-base leading-snug mb-2 group-hover:text-primary-600 transition-colors line-clamp-2">
        {title}
      </h2>
      <p class="text-sm text-gray-500 leading-relaxed line-clamp-2 mb-3">
        {description}
      </p>
      <div class="flex items-center justify-between">
        <time class="text-xs text-gray-400 flex items-center gap-1">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          {dateStr}
        </time>
        <span class="text-xs text-primary-600 font-medium flex items-center gap-0.5">
          続きを読む
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </span>
      </div>
    </div>
  </a>
</article>
