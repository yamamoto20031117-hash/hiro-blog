---
import { amazonUrl, amazonSearch } from '@/consts';
import Thumb from '@/components/Thumb.astro';

// ランキング表示部品。item は asin（→直リンク）か url（→検索等）どちらかを指定。
export interface RankItem {
  name: string;
  price: string;
  comment: string;        // 選んだ理由・おすすめポイント
  pros?: string[];        // 箇条書きの強み
  rating?: number;        // 1〜5
  image?: string;
  icon?: string;          // 画像が無い時に出す絵文字（例: 🎧🔋）
  badge?: string;
  asin?: string;          // あれば amazonUrl(asin) で直リンク
  url?: string;           // asinが無い場合の遷移先（amazonSearch等）
  searchKeyword?: string; // url も asin も無い時のフォールバック検索語
  productSlug?: string;   // /products/[slug] の詳細レビューがある場合
}

interface Props {
  items: RankItem[];
}
const { items } = Astro.props;

const medal = (i: number) => (i === 0 ? '🥇' : i === 1 ? '🥈' : i === 2 ? '🥉' : '');
const tileColors = ['blue', 'green', 'purple', 'teal', 'orange'];
const linkOf = (it: RankItem) =>
  it.asin ? amazonUrl(it.asin) : it.url ? it.url : amazonSearch(it.searchKeyword ?? it.name);
---

<div class="not-prose space-y-4">
  {items.map((it, i) => (
    <div class={`relative rounded-2xl border bg-white p-4 sm:p-5 ${i < 3 ? 'border-accent-500/40 shadow-sm' : 'border-gray-200'}`}>
      <div class="flex gap-4">
        <!-- 順位 -->
        <div class="flex-shrink-0 flex flex-col items-center w-10 sm:w-12">
          <span class="text-2xl sm:text-3xl leading-none">{medal(i) || ''}</span>
          <span class={`font-extrabold ${i < 3 ? 'text-accent-600' : 'text-gray-400'} ${medal(i) ? 'text-sm mt-0.5' : 'text-2xl'}`}>
            {i + 1}<span class="text-xs">位</span>
          </span>
        </div>

        <!-- 画像/絵文字タイル -->
        <div class="flex-shrink-0 w-20 h-20 sm:w-24 sm:h-24 rounded-xl overflow-hidden shadow-sm">
          <Thumb image={it.image} emoji={it.icon ?? '🛒'} color={tileColors[i % tileColors.length]} alt={it.name} class="w-full h-full" />
        </div>

        <!-- 本体 -->
        <div class="flex-1 min-w-0">
          {it.badge && (
            <span class="inline-block bg-accent-500 text-white text-[10px] font-bold px-2 py-0.5 rounded-full mb-1">{it.badge}</span>
          )}
          <h3 class="font-bold text-gray-900 text-sm sm:text-base leading-snug">{it.name}</h3>

          {it.rating && (
            <div class="text-xs text-yellow-500 mt-0.5">
              {'★'.repeat(Math.round(it.rating))}<span class="text-gray-200">{'★'.repeat(5 - Math.round(it.rating))}</span>
              <span class="text-gray-500 ml-1">{it.rating.toFixed(1)}</span>
            </div>
          )}

          <p class="text-xs sm:text-sm text-gray-600 mt-1.5 leading-relaxed">{it.comment}</p>

          {it.pros && it.pros.length > 0 && (
            <ul class="mt-2 space-y-1">
              {it.pros.map((p) => (
                <li class="flex items-start gap-1.5 text-xs text-gray-700">
                  <span class="text-green-500 mt-0.5">✓</span><span>{p}</span>
                </li>
              ))}
            </ul>
          )}

          <div class="flex items-center justify-between gap-2 flex-wrap mt-3">
            <span class="text-primary-700 font-bold text-base">{it.price}</span>
            <div class="flex items-center gap-2">
              {it.productSlug && (
                <a href={`/products/${it.productSlug}`} class="inline-flex items-center gap-1 text-primary-600 hover:text-primary-800 text-xs font-semibold">
                  詳しくレビュー
                </a>
              )}
              <a
                href={linkOf(it)}
                target="_blank"
                rel="sponsored noopener noreferrer nofollow"
                class="inline-flex items-center gap-1.5 bg-accent-500 hover:bg-accent-600 text-white text-sm font-bold px-4 py-2 rounded-lg transition-colors shadow-sm"
              >
                Amazonで見る
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  ))}
</div>
