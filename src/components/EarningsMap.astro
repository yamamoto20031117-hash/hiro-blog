---
// 時給マップ - D3.js
// ズームアウト: 都道府県ポリゴン色分け
// クリック: 市区町村ポリゴン境界で色分け
---

<div class="relative select-none">
  <div id="map-wrap"
       class="rounded-2xl border border-slate-200 overflow-hidden shadow-sm"
       style="height:520px; background:#dbeafe; position:relative;">

    <svg id="jmap" style="width:100%;height:100%;display:block;cursor:grab;"></svg>

    <!-- モード切替ナビ -->
    <div id="map-nav" class="absolute top-3 left-3 z-10 flex gap-1">
      <button type="button" id="map-btn-pref"
        class="bg-blue-600 text-white backdrop-blur rounded-lg shadow px-2.5 py-1.5 text-xs font-bold border border-blue-600 transition-colors">
        🗾 都道府県
      </button>
      <button type="button" id="map-btn-city"
        class="bg-white/95 text-gray-400 backdrop-blur rounded-lg shadow px-2.5 py-1.5 text-xs font-bold border border-gray-200 transition-colors cursor-not-allowed" disabled>
        📍 市区町村
      </button>
    </div>

    <!-- フィルター -->
    <div id="map-filters" class="absolute top-12 left-3 z-10 flex flex-col gap-1.5">
      <!-- 曜日フィルター -->
      <div class="bg-white/95 backdrop-blur rounded-lg shadow border border-gray-200 px-2 py-1.5 flex items-center gap-1 flex-wrap">
        <span class="text-[10px] text-gray-400 mr-0.5">📅</span>
        <button type="button" data-day="all" class="map-day-btn text-[10px] px-1.5 py-0.5 rounded font-bold bg-blue-600 text-white">全て</button>
        <button type="button" data-day="mon" class="map-day-btn text-[10px] px-1.5 py-0.5 rounded font-bold bg-gray-100 text-gray-500 hover:bg-gray-200">月</button>
        <button type="button" data-day="tue" class="map-day-btn text-[10px] px-1.5 py-0.5 rounded font-bold bg-gray-100 text-gray-500 hover:bg-gray-200">火</button>
        <button type="button" data-day="wed" class="map-day-btn text-[10px] px-1.5 py-0.5 rounded font-bold bg-gray-100 text-gray-500 hover:bg-gray-200">水</button>
        <button type="button" data-day="thu" class="map-day-btn text-[10px] px-1.5 py-0.5 rounded font-bold bg-gray-100 text-gray-500 hover:bg-gray-200">木</button>
        <button type="button" data-day="fri" class="map-day-btn text-[10px] px-1.5 py-0.5 rounded font-bold bg-gray-100 text-gray-500 hover:bg-gray-200">金</button>
        <button type="button" data-day="sat" class="map-day-btn text-[10px] px-1.5 py-0.5 rounded font-bold bg-gray-100 text-gray-500 hover:bg-gray-200">土</button>
        <button type="button" data-day="sun" class="map-day-btn text-[10px] px-1.5 py-0.5 rounded font-bold bg-gray-100 text-gray-500 hover:bg-gray-200">日</button>
      </div>
      <!-- 乗り物フィルター -->
      <div class="bg-white/95 backdrop-blur rounded-lg shadow border border-gray-200 px-2 py-1.5 flex items-center gap-1 flex-wrap">
        <span class="text-[10px] text-gray-400 mr-0.5">🚗</span>
        <button type="button" data-vehicle="all"          class="map-veh-btn text-[10px] px-1.5 py-0.5 rounded font-bold bg-blue-600 text-white">全て</button>
        <button type="button" data-vehicle="walk_bicycle"  class="map-veh-btn text-[10px] px-1.5 py-0.5 rounded font-bold bg-gray-100 text-gray-500 hover:bg-gray-200">🚲徒歩</button>
        <button type="button" data-vehicle="moped50"       class="map-veh-btn text-[10px] px-1.5 py-0.5 rounded font-bold bg-gray-100 text-gray-500 hover:bg-gray-200">🛵原付</button>
        <button type="button" data-vehicle="motorcycle"    class="map-veh-btn text-[10px] px-1.5 py-0.5 rounded font-bold bg-gray-100 text-gray-500 hover:bg-gray-200">🏍バイク</button>
        <button type="button" data-vehicle="kei_car"       class="map-veh-btn text-[10px] px-1.5 py-0.5 rounded font-bold bg-gray-100 text-gray-500 hover:bg-gray-200">🚗軽自動車</button>
      </div>
    </div>

    <!-- ズームボタン -->
    <div class="absolute top-3 right-3 flex flex-col gap-1 z-10">
      <button id="btn-in"  class="w-8 h-8 bg-white rounded-lg shadow font-bold text-lg hover:bg-gray-50 flex items-center justify-center border border-gray-200 text-gray-700">+</button>
      <button id="btn-out" class="w-8 h-8 bg-white rounded-lg shadow font-bold text-lg hover:bg-gray-50 flex items-center justify-center border border-gray-200 text-gray-700">−</button>
    </div>

    <!-- 凡例 -->
    <div class="absolute bottom-3 left-3 bg-white/95 backdrop-blur rounded-xl shadow px-3 py-2.5 text-[10px] z-10 border border-gray-100">
      <p class="font-bold text-gray-600 mb-1.5">平均時給（¥500刻み）</p>
      <div class="space-y-1">
        <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-sm inline-block" style="background:#06b6d4"></span>¥3,000以上</span>
        <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-sm inline-block" style="background:#22c55e"></span>¥2,500〜2,999</span>
        <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-sm inline-block" style="background:#84cc16"></span>¥2,000〜2,499</span>
        <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-sm inline-block" style="background:#facc15"></span>¥1,500〜1,999</span>
        <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-sm inline-block" style="background:#fb923c"></span>¥1,000〜1,499</span>
        <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-sm inline-block" style="background:#ef4444"></span>¥1,000未満</span>
        <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-sm inline-block bg-slate-200"></span>データなし</span>
        <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-sm inline-block" style="background:#1e1e1e"></span>Uber非対応</span>
      </div>
      <p class="text-gray-400 mt-1.5 leading-tight">都道府県タップで市区町村を表示</p>
    </div>

    <!-- 情報パネル（右下固定カード） -->
    <div id="map-popup"
         class="hidden absolute bottom-3 right-3 z-20 bg-white/95 backdrop-blur rounded-xl shadow-xl border border-gray-200 pointer-events-auto"
         style="width:210px;">
      <button id="pp-close" type="button"
        class="absolute top-1 right-1.5 text-gray-300 hover:text-gray-500 text-sm leading-none">✕</button>
      <div class="px-3 py-2.5">
        <p class="flex items-baseline gap-1 mb-0.5">
          <span id="pp-city" class="font-bold text-gray-900 text-sm"></span>
          <span id="pp-pref" class="text-[10px] text-gray-400"></span>
        </p>
        <p id="pp-rate" class="text-xl font-black leading-tight"></p>
        <p id="pp-tier" class="text-[10px] font-semibold px-1.5 py-0.5 rounded-full w-fit mt-0.5"></p>
        <div id="pp-breakdown" class="hidden border-t border-gray-100 mt-2 pt-1.5 space-y-0.5">
          <p class="text-[10px] text-gray-400 font-bold">内訳（平均）</p>
          <div class="flex justify-between text-[11px]">
            <span class="text-gray-500">正味の料金</span>
            <span id="pp-base" class="font-bold text-gray-700"></span>
          </div>
          <div class="flex justify-between text-[11px]">
            <span class="text-gray-500">プロモーション</span>
            <span id="pp-promo" class="font-bold text-blue-600"></span>
          </div>
        </div>
        <p id="pp-count"   class="text-[11px] text-gray-400 mt-1.5"></p>
        <p id="pp-vehicle" class="text-[11px] text-gray-400"></p>
      </div>
    </div>

    <!-- ローディング -->
    <div id="map-loading"
         class="absolute inset-0 flex flex-col items-center justify-center bg-blue-50/80 backdrop-blur-sm">
      <div class="text-4xl mb-3 animate-bounce">🗾</div>
      <p id="loading-msg" class="text-sm text-slate-500 font-medium">地図データを読み込み中...</p>
      <p class="text-xs text-slate-400 mt-1">初回のみ数秒かかることがあります</p>
    </div>

    <!-- 市区町村ローディング -->
    <div id="city-loading"
         class="hidden absolute top-12 left-3 bg-white/95 backdrop-blur rounded-lg shadow px-3 py-2 text-xs z-10 border border-gray-100">
      <span class="animate-pulse">⏳</span> 市区町村データ読込中...
    </div>

  </div>
</div>

<script>
  // ===== カラースケール =====
  function rateColor(avg: number): string {
    if (avg >= 3000) return '#06b6d4';
    if (avg >= 2500) return '#22c55e';
    if (avg >= 2000) return '#84cc16';
    if (avg >= 1500) return '#facc15';
    if (avg >= 1000) return '#fb923c';
    return '#ef4444';
  }
  function rateLabel(avg: number): string {
    if (avg >= 3000) return '¥3,000以上';
    if (avg >= 2500) return '¥2,500〜2,999';
    if (avg >= 2000) return '¥2,000〜2,499';
    if (avg >= 1500) return '¥1,500〜1,999';
    if (avg >= 1000) return '¥1,000〜1,499';
    return '¥1,000未満';
  }

  // ===== 都道府県 名前⇔コード 双方向マッピング =====
  const PREF_LIST = [
    '北海道','青森','岩手','宮城','秋田','山形','福島',
    '茨城','栃木','群馬','埼玉','千葉','東京','神奈川',
    '新潟','富山','石川','福井','山梨','長野',
    '岐阜','静岡','愛知','三重',
    '滋賀','京都','大阪','兵庫','奈良','和歌山',
    '鳥取','島根','岡山','広島','山口',
    '徳島','香川','愛媛','高知',
    '福岡','佐賀','長崎','熊本','大分','宮崎','鹿児島','沖縄',
  ];
  // 名前→コード  ("東京" → "13")
  const PREF_CODE: Record<string, string> = {};
  // ID番号→名前  (13 → "東京")
  const PREF_BY_ID: Record<number, string> = {};
  PREF_LIST.forEach((name, i) => {
    const code = String(i + 1).padStart(2, '0');
    PREF_CODE[name] = code;
    PREF_BY_ID[i + 1] = name;
  });

  // 英語名→日本語名
  const ENG_TO_JA: Record<string, string> = {
    'Hokkaido':'北海道','Aomori':'青森','Iwate':'岩手','Miyagi':'宮城','Akita':'秋田',
    'Yamagata':'山形','Fukushima':'福島','Ibaraki':'茨城','Tochigi':'栃木','Gunma':'群馬',
    'Saitama':'埼玉','Chiba':'千葉','Tokyo':'東京','Kanagawa':'神奈川','Niigata':'新潟',
    'Toyama':'富山','Ishikawa':'石川','Fukui':'福井','Yamanashi':'山梨','Nagano':'長野',
    'Gifu':'岐阜','Shizuoka':'静岡','Aichi':'愛知','Mie':'三重','Shiga':'滋賀',
    'Kyoto':'京都','Osaka':'大阪','Hyogo':'兵庫','Nara':'奈良','Wakayama':'和歌山',
    'Tottori':'鳥取','Shimane':'島根','Okayama':'岡山','Hiroshima':'広島','Yamaguchi':'山口',
    'Tokushima':'徳島','Kagawa':'香川','Ehime':'愛媛','Kochi':'高知','Fukuoka':'福岡',
    'Saga':'佐賀','Nagasaki':'長崎','Kumamoto':'熊本','Oita':'大分','Miyazaki':'宮崎',
    'Kagoshima':'鹿児島','Okinawa':'沖縄',
  };

  // ===== 離島フィルタ用: 本土バウンディングボックス (SVG投影後の近似) =====
  // Uber配達圏外の離島（小笠原、伊豆諸島、トカラ列島等）を除外するため
  // 緯度約30°〜46°, 経度約128°〜146° の本土エリアのみ対象
  const MAINLAND_LAT = [30.0, 46.0];
  const MAINLAND_LNG = [128.0, 146.0];

  // 都道府県ラベル位置のオーバーライド（離島でcentroidがずれる県）
  // [経度, 緯度] で指定 → projで変換して使う
  const PREF_LABEL_POS: Record<string, [number, number]> = {
    '東京':     [139.75, 35.68],   // 23区中心
    '鹿児島':   [130.55, 31.56],   // 鹿児島市付近
    '沖縄':     [127.68, 26.34],   // 那覇市付近
    '長崎':     [129.87, 32.75],   // 長崎市付近
    '北海道':   [143.20, 43.06],   // 札幌付近
  };

  // GeoJSONプロパティから日本語都道府県名を取得（あらゆるフォーマットに対応）
  // 「北海道」は「道」を除去しない（PREF_LISTのキーが「北海道」のため）
  function stripSuffix(name: string): string {
    if (name === '北海道') return '北海道';
    return name.replace(/[都道府県]$/,'');
  }
  function getPrefNameJa(props: any): string {
    // nam_ja があればそれを使う
    if (props.nam_ja) return stripSuffix(props.nam_ja);
    // name が日本語なら使う
    if (props.name && /[\u3000-\u9fff]/.test(props.name)) return stripSuffix(props.name);
    // nam が英語 → 日本語変換
    if (props.nam && ENG_TO_JA[props.nam]) return ENG_TO_JA[props.nam];
    // id ベース
    if (props.id && PREF_BY_ID[props.id]) return PREF_BY_ID[props.id];
    // フォールバック
    const raw = (props.name ?? props.nam ?? '');
    return stripSuffix(raw);
  }

  // ===== Uber Eats 対応エリア =====
  const UBER_AREA: Record<string, Set<string>> = {
    '北海道': new Set(['札幌市','江別市','千歳市','恵庭市','石狩市','北広島市','旭川市','函館市','北斗市','釧路市','帯広市','苫小牧市','小樽市','室蘭市','登別市','岩見沢市','北見市','東神楽町','音更町','倶知安町','七飯町','南幌町','滝川市']),
    '青森': new Set(['青森市','八戸市','弘前市','むつ市','三沢市','平川市','六戸町','十和田市']),
    '岩手': new Set(['盛岡市','一関市','北上市','滝沢市','花巻市','奥州市']),
    '宮城': new Set(['仙台市','名取市','多賀城市','塩竈市','富谷市','利府町','石巻市','大崎市','大河原町','岩沼市','東松島市','登米市','松島町','七ヶ浜町','大和町','亘理町']),
    '秋田': new Set(['秋田市','大仙市','横手市','北秋田市','能代市','大館市','由利本荘市']),
    '山形': new Set(['山形市','鶴岡市','酒田市','天童市','東根市','米沢市','中山町','寒河江市']),
    '福島': new Set(['福島市','郡山市','いわき市','二本松市','会津若松市','南相馬市','猪苗代町','白河市','須賀川市','伊達市','相馬市']),
    '茨城': new Set(['水戸市','つくば市','土浦市','日立市','ひたちなか市','筑西市','牛久市','龍ケ崎市','取手市','守谷市','古河市','かすみがうら市','つくばみらい市','利根町','坂東市','常総市','東海村','神栖市','笠間市','結城市','那珂市','阿見町','鹿嶋市','茨城町','境町']),
    '栃木': new Set(['宇都宮市','小山市','那須塩原市','栃木市','足利市','佐野市','下野市','壬生町','大田原市','野木町','鹿沼市','上三川町']),
    '群馬': new Set(['前橋市','高崎市','太田市','伊勢崎市','館林市','渋川市','みどり市','吉岡町','大泉町','富岡市','桐生市','藤岡市','邑楽町','安中市','千代田町','板倉町','明和町','榛東村','玉村町']),
    '埼玉': new Set(['さいたま市','川越市','川口市','所沢市','越谷市','草加市','春日部市','上尾市','熊谷市','新座市','狭山市','久喜市','入間市','深谷市','朝霞市','戸田市','志木市','和光市','富士見市','三郷市','蕨市','八潮市','ふじみ野市','坂戸市','鶴ヶ島市','桶川市','北本市','蓮田市','吉川市','鴻巣市','行田市','加須市','羽生市','白岡市','秩父市','飯能市','東松山市','日高市','三芳町','上里町','吉見町','宮代町','小川町','川島町','幸手市','本庄市','杉戸町','松伏町','毛呂山町','滑川町','鳩山町','神川町','皆野町','長瀞町','嵐山町','寄居町']),
    '千葉': new Set(['千葉市','船橋市','松戸市','市川市','柏市','市原市','八千代市','流山市','野田市','我孫子市','浦安市','習志野市','鎌ケ谷市','木更津市','君津市','袖ケ浦市','成田市','佐倉市','四街道市','印西市','茂原市','八街市','東金市','山武市','大網白里市','富津市','富里市','旭市','白井市','酒々井町','香取市','銚子市','いすみ市','栄町','芝山町','館山市']),
    '東京': new Set(['千代田区','中央区','港区','新宿区','文京区','台東区','墨田区','江東区','品川区','目黒区','大田区','世田谷区','渋谷区','中野区','杉並区','豊島区','北区','荒川区','板橋区','練馬区','足立区','葛飾区','江戸川区','八王子市','立川市','武蔵野市','三鷹市','青梅市','府中市','昭島市','調布市','町田市','小金井市','小平市','日野市','東村山市','国分寺市','国立市','福生市','狛江市','東大和市','清瀬市','東久留米市','武蔵村山市','多摩市','稲城市','羽村市','あきる野市','西東京市','日の出町','瑞穂町']),
