    '新潟': new Set(['新潟市','長岡市','上越市','三条市','新発田市','柏崎市','妙高市','燕市']),
    '富山': new Set(['富山市','高岡市','砺波市','射水市','黒部市','立山町']),
    '石川': new Set(['金沢市','白山市','野々市市','加賀市','内灘町','小松市','能美市']),
    '福井': new Set(['福井市','敦賀市','越前市','鯖江市','坂井市','永平寺町']),
    '山梨': new Set(['甲府市','中央市','南アルプス市','富士吉田市','山中湖村','山梨市','昭和町','甲州市','甲斐市','笛吹市','韮崎市','北杜市']),
    '長野': new Set(['長野市','松本市','上田市','下諏訪町','中野市','佐久市','千曲市','塩尻市','安曇野市','小諸市','茅野市','軽井沢町','飯田市','須坂市','御代田町','高森町']),
