  // Uberエリアかどうか判定
  function isUberArea(prefName: string, cityName: string): boolean {
    const cities = UBER_AREA[prefName];
    if (!cities) return false;
    if (cities.has(cityName)) return true;
    // 「名古屋市中区」→「名古屋市」で部分マッチ
    for (const c of cities) {
      if (cityName.startsWith(c) || c.startsWith(cityName)) return true;
    }
    return false;
  }

  // ===== データ（ユーザー投稿のみ） =====
  const DEMO: any[] = [];

  const V_LABEL: Record<string,string> = {
    walk_bicycle:'自転車&徒歩', moped50:'原付(50cc)', motorcycle:'バイク(51cc〜)', kei_car:'軽自動車',
    // 旧キー互換
    bicycle:'自転車', moped:'原付', bike:'バイク', car:'車',
  };

  // ワンタイムリセット: 旧デモデータ＋テストデータをクリア
  if (!localStorage.getItem('uber_data_reset_v2')) {
    localStorage.removeItem('uber_data');
    localStorage.setItem('uber_data_reset_v2', '1');
  }

  // ===== フィルター状態 =====
  let filterDay = 'all';     // 'all' | 'mon' | 'tue' | ...
  let filterVehicle = 'all'; // 'all' | 'bicycle' | 'moped' | 'bike' | 'car'

  function getAllData() {
    let saved: any[] = [];
    try { saved = JSON.parse(localStorage.getItem('uber_data') ?? '[]'); } catch {}
    let data = [...DEMO, ...saved];
    if (filterDay !== 'all') {
      data = data.filter(d => d.dayOfWeek === filterDay || d.dayType === filterDay);
    }
    if (filterVehicle !== 'all') {
      data = data.filter(d => d.vehicle === filterVehicle);
    }
    return data;
  }

  // ===== 都道府県レベル集計 =====
  function aggregatePref(): Map<string, {avg:number; count:number; vehicles:string[]; cities:string[]}> {
    const all = getAllData();
    const map = new Map<string, {total:number; count:number; v:Set<string>; c:Set<string>}>();
    for (const d of all) {
      if (!d.prefecture) continue;
      const key = stripSuffix(d.prefecture);
      if (!map.has(key)) map.set(key, {total:0, count:0, v:new Set(), c:new Set()});
      const r = d.hourlyRate ?? (d.hours > 0 ? Math.round((d.earnings - (d.tip || 0)) / d.hours) : 0);
      const e = map.get(key)!;
      e.total += r; e.count += 1;
      if (d.vehicle) e.v.add(d.vehicle);
      if (d.city)    e.c.add(d.city);
    }
    const result = new Map<string, {avg:number; count:number; vehicles:string[]; cities:string[]}>();
    for (const [key, v] of map) {
      result.set(key, {
        avg: Math.round(v.total / v.count), count: v.count,
        vehicles: [...v.v].map(x => V_LABEL[x] ?? x), cities: [...v.c],
      });
    }
    return result;
  }

  // ===== 市区町村レベル集計 =====
  function aggregateCity(prefName: string): Map<string, {avg:number; count:number; vehicles:string[]; avgBase:number; avgPromo:number}> {
    const all = getAllData();
    const normalPref = stripSuffix(prefName);
    const map = new Map<string, {total:number; count:number; v:Set<string>; baseSum:number; promoSum:number; breakdownCount:number}>();
    for (const d of all) {
      if (!d.city) continue;
      const dp = stripSuffix(d.prefecture || '');
      if (dp !== normalPref) continue;
      const key = d.city;
      if (!map.has(key)) map.set(key, {total:0, count:0, v:new Set(), baseSum:0, promoSum:0, breakdownCount:0});
      const r = d.hourlyRate ?? (d.hours > 0 ? Math.round((d.earnings - (d.tip || 0)) / d.hours) : 0);
      const e = map.get(key)!;
      e.total += r; e.count += 1;
      if (d.vehicle) e.v.add(d.vehicle);
      if (d.baseFare || d.promotion) {
        e.baseSum += (d.baseFare || 0);
        e.promoSum += (d.promotion || 0);
        e.breakdownCount += 1;
      }
    }
    const result = new Map<string, {avg:number; count:number; vehicles:string[]; avgBase:number; avgPromo:number}>();
    for (const [key, v] of map) {
      result.set(key, {
        avg: Math.round(v.total / v.count), count: v.count,
        vehicles: [...v.v].map(x => V_LABEL[x] ?? x),
        avgBase: v.breakdownCount > 0 ? Math.round(v.baseSum / v.breakdownCount) : 0,
        avgPromo: v.breakdownCount > 0 ? Math.round(v.promoSum / v.breakdownCount) : 0,
      });
    }
    return result;
  }

  // ===== スクリプト読み込み =====
  function loadScript(src: string, globalName: string): Promise<void> {
    return new Promise((resolve, reject) => {
      if ((window as any)[globalName]) { resolve(); return; }
      const existing = document.querySelector(`script[src="${src}"]`);
      if (existing) {
        const poll = () => { if ((window as any)[globalName]) resolve(); else setTimeout(poll, 50); };
        poll(); return;
      }
      const s = document.createElement('script');
      s.src = src;
      s.onload = () => {
        const poll = () => { if ((window as any)[globalName]) resolve(); else setTimeout(poll, 50); };
        poll();
      };
      s.onerror = () => reject(new Error(`Script load failed: ${src}`));
      document.head.appendChild(s);
    });
  }

  // ===== グローバル =====
  let d3: any, topojson: any, zoom: any, svg: any, g: any, pathFn: any;
  let activePref: string | null = null;
  let resettingToPref = false; // 都道府県モードへの復帰中フラグ（自動ドリル防止）
  const cityCache = new Map<string, any>();

  // ポップアップ追従用: SVG空間での座標を保持
  let popupSvgX: number | null = null;
  let popupSvgY: number | null = null;
  let popupVisible = false;

  // ポップアップ再描画用: 現在表示中の地域情報
  let popupCityName: string = '';
  let popupPrefName: string = '';
  let popupCityProps: any = null; // D3 feature properties (市区町村モード時)

  // ===== 市区町村TopoJSON読み込み =====
  async function loadCityTopo(prefCode: string): Promise<any> {
    if (cityCache.has(prefCode)) return cityCache.get(prefCode);
    const urls = [
      `https://cdn.jsdelivr.net/gh/smartnews-smri/japan-topography@main/data/municipality/topojson/s0010/N03-21_${prefCode}_210101.json`,
      `https://raw.githubusercontent.com/smartnews-smri/japan-topography/main/data/municipality/topojson/s0010/N03-21_${prefCode}_210101.json`,
    ];
    let lastErr: any;
    for (const url of urls) {
      try {
        console.log('[map] loading:', url);
        const data = await d3.json(url);
        if (data && data.objects) {
          console.log('[map] loaded OK, objects:', Object.keys(data.objects));
          cityCache.set(prefCode, data);
          return data;
        }
      } catch (e) { lastErr = e; console.warn('[map] failed:', url, e); }
    }
    throw lastErr || new Error('TopoJSON取得失敗');
  }

  // ===== TopoJSONの市区町村名取得 =====
  function getCityName(props: any): string {
    const gun = props.N03_003 || '';
    const city = props.N03_004 || '';
    if (gun && city) return gun + city;
    return city || gun || '';
  }

  // ===== 市区町村データとマッチング =====
  function matchCityRate(props: any, cityRates: Map<string, any>): any {
    const name = getCityName(props);
    if (cityRates.has(name)) return cityRates.get(name);
    const short = props.N03_004 || '';
    if (short && cityRates.has(short)) return cityRates.get(short);
    return undefined;
  }

  // ===== 地図構築 =====
  function buildMap(prefData: any) {
    const wrap = document.getElementById('map-wrap')!;
    const W = wrap.offsetWidth, H = wrap.offsetHeight;

    svg = d3.select('#jmap');
    svg.append('rect').attr('x',0).attr('y',0).attr('width',W).attr('height',H).attr('fill','#bfdbfe');

    const proj = d3.geoMercator().center([137.0, 37.5]).scale(1600).translate([W/2, H/2]);
    pathFn = d3.geoPath().projection(proj);
    g = svg.append('g');
    const prefRates = aggregatePref();

    // DEBUG: 最初のfeatureのプロパティを出力
    if (prefData.features.length > 0) {
      console.log('[map] GeoJSON sample properties:', JSON.stringify(prefData.features[0].properties));
    }

    // ── 都道府県ポリゴン ──
    g.append('g').attr('class','pref-layer')
      .selectAll('path')
      .data(prefData.features)
      .enter().append('path')
      .attr('d', pathFn)
      .attr('fill', (d: any) => {
        const jaName = getPrefNameJa(d.properties);
        if (!UBER_AREA[jaName]) return '#1e1e1e'; // Uber非対応県は黒
        const r = prefRates.get(jaName);
        return r ? rateColor(r.avg) : '#e2e8f0';
      })
      .attr('stroke', '#94a3b8')
      .attr('stroke-width', 0.6)
      .style('cursor', 'pointer')
      .on('mouseover', function(this: Element) { d3.select(this).attr('opacity', 0.75); })
      .on('mouseout',  function(this: Element) { d3.select(this).attr('opacity', 1); })
      .on('click', function(event: MouseEvent, d: any) {
        event.stopPropagation();
        const jaName = getPrefNameJa(d.properties);
        console.log('[map] clicked prefecture:', jaName, 'props:', d.properties);
        if (activePref && activePref === jaName) return; // 同じ県なら無視
        if (activePref) {
          // 別の県 → 市区町村をクリアして新しい県にドリルダウン
          g.select('.city-layer').selectAll('*').remove();
          g.select('.city-labels').selectAll('*').remove();
          activePref = null;
        }
        drillDown(jaName, d);
      });

    // ── 都道府県名ラベル（離島補正付き）──
    const labelProj = d3.geoMercator().center([137.0, 37.5]).scale(1600).translate([W/2, H/2]);
    g.append('g').attr('class','pref-labels')
      .selectAll('text')
      .data(prefData.features)
      .enter().append('text')
      .attr('x', (d: any) => {
        const name = getPrefNameJa(d.properties);
        if (PREF_LABEL_POS[name]) return labelProj(PREF_LABEL_POS[name])[0];
        try { return pathFn.centroid(d)[0]; } catch { return 0; }
      })
      .attr('y', (d: any) => {
        const name = getPrefNameJa(d.properties);
        if (PREF_LABEL_POS[name]) return labelProj(PREF_LABEL_POS[name])[1];
        try { return pathFn.centroid(d)[1] + 2; } catch { return 0; }
      })
      .attr('text-anchor', 'middle')
      .attr('font-size', '5px')
      .attr('font-family', 'sans-serif')
      .attr('fill', '#1e293b')
      .attr('pointer-events', 'none')
      .attr('opacity', 0)
      .text((d: any) => getPrefNameJa(d.properties));

    // ── 市区町村レイヤー（空で初期化） ──
    g.append('g').attr('class','city-layer');
    g.append('g').attr('class','city-labels');

    // ── ズーム制御（Google Map風ラベル）──
    let zoomTimer: any = null;
    zoom = d3.zoom().scaleExtent([0.8, 40])
      .on('zoom', (event: any) => {
        const k = event.transform.k;
        g.attr('transform', event.transform);
        g.select('.pref-layer').selectAll('path').attr('stroke-width', 0.6 / k);
        g.select('.city-layer').selectAll('path').attr('stroke-width', 0.3 / k);

        // 都道府県名ラベル: 画面上11px一定、k<1.8 or k>10で非表示
        const prefOpacity = (!activePref && k >= 1.8 && k <= 10) ? 1 : 0;
        g.select('.pref-labels').selectAll('text')
          .attr('opacity', prefOpacity)
          .attr('font-size', `${11 / k}px`);

        // 市区町村名ラベル: 画面上10px一定、k=18〜60で表示（重なり防止のため遅め）
        const cityOpacity = (activePref && k >= 18 && k <= 60) ? Math.min(1, (k - 18) / 3) : 0;
        g.select('.city-labels').selectAll('text')
          .attr('opacity', cityOpacity)
          .attr('font-size', `${10 / k}px`);

        // ポップアップは下部固定のため追従不要

        // ズーム時の自動ドリルダウン（k>=6で中央の都道府県を展開）
        // resettingToPref中はトランジションでk>=6を通過しても無視
        if (!activePref && !resettingToPref && k >= 6) {
          clearTimeout(zoomTimer);
          zoomTimer = setTimeout(() => autoDrillByCenter(event.transform), 400);
        }
      });

    svg.call(zoom);
    svg.on('mousedown', () => svg.style('cursor','grabbing'))
       .on('mouseup',   () => svg.style('cursor','grab'));

    document.getElementById('btn-in')?.addEventListener('click', () =>
      svg.transition().duration(300).call(zoom.scaleBy, 1.6));
    document.getElementById('btn-out')?.addEventListener('click', () =>
      svg.transition().duration(300).call(zoom.scaleBy, 0.625));

    // ナビ: 都道府県ボタンで戻る
    document.getElementById('map-btn-pref')?.addEventListener('click', () => {
      if (activePref) resetToPrefs();
    });
  }

  // ===== 都道府県クリック → 市区町村ドリルダウン =====
  async function drillDown(prefName: string, prefFeature: any) {
    const code = PREF_CODE[prefName];
    console.log('[map] drillDown:', prefName, '→ code:', code);
    if (!code) {
      console.error('[map] 都道府県コード見つからず:', prefName);
      return;
    }

    document.getElementById('city-loading')!.classList.remove('hidden');

    // ナビボタン: 市区町村タブをアクティブに
    const btnPref = document.getElementById('map-btn-pref')!;
    const btnCity = document.getElementById('map-btn-city')!;
    btnPref.className = 'bg-white/95 text-gray-700 backdrop-blur rounded-lg shadow px-2.5 py-1.5 text-xs font-bold border border-gray-200 transition-colors hover:bg-gray-50 cursor-pointer';
    btnCity.className = 'bg-blue-600 text-white backdrop-blur rounded-lg shadow px-2.5 py-1.5 text-xs font-bold border border-blue-600 transition-colors';
    btnCity.textContent = `📍 ${prefName}`;
    (btnCity as HTMLButtonElement).disabled = false;

    try {
      // topojson-client
      if (!topojson) {
        await loadScript('https://cdn.jsdelivr.net/npm/topojson-client@3.1.0/dist/topojson-client.min.js', 'topojson');
        topojson = (window as any).topojson;
      }
      if (!topojson) throw new Error('topojson-client 読み込み失敗');

      // 市区町村TopoJSON取得
      const topo = await loadCityTopo(code);
      const objKey = Object.keys(topo.objects)[0];
      const geoData = topojson.feature(topo, topo.objects[objKey]);
      console.log('[map] municipality features:', geoData.features.length,
                  'sample props:', geoData.features[0]?.properties);

      activePref = prefName;
      const cityRates = aggregateCity(prefName);

      // データのある市区町村名セット
      const dataNames = new Set(cityRates.keys());
      console.log('[map] cities with data:', [...dataNames]);

      // 離島除外: 本土エリア内のfeatureのみ抽出
      const mainlandFeatures = geoData.features.filter((d: any) => {
        try {
          const c = d3.geoCentroid(d); // [lng, lat]
          if (!c || !isFinite(c[0])) return false;
          return c[1] >= MAINLAND_LAT[0] && c[1] <= MAINLAND_LAT[1]
              && c[0] >= MAINLAND_LNG[0] && c[0] <= MAINLAND_LNG[1];
        } catch { return false; }
      });

      // データのある市区町村にマッチするfeature
      const matchedFeatures = mainlandFeatures.filter((d: any) => {
        return matchCityRate(d.properties, cityRates) !== undefined;
      });

      console.log('[map] matched:', matchedFeatures.length, '/ mainland:', mainlandFeatures.length);

      // 都道府県レイヤーを薄く
      g.select('.pref-layer').selectAll('path')
        .transition().duration(300)
        .attr('fill-opacity', 0.35)
        .attr('stroke-opacity', 0.5);
      g.select('.pref-labels').selectAll('text').attr('opacity', 0);

      // 市区町村ポリゴン描画（全市区町村を1レイヤーで）
      const cityLayer = g.select('.city-layer');
      cityLayer.selectAll('*').remove();

      cityLayer.selectAll('path')
        .data(mainlandFeatures)
        .enter().append('path')
        .attr('d', pathFn)
        .attr('fill', (d: any) => {
          const name = getCityName(d.properties);
          if (!isUberArea(prefName, name)) return '#1e1e1e'; // Uber非対応は黒
          const r = matchCityRate(d.properties, cityRates);
          return r ? rateColor(r.avg) : '#e2e8f0';
        })
        .attr('stroke', '#94a3b8')
        .attr('stroke-width', 0.25)
        .attr('fill-opacity', 0)
        .style('cursor', 'pointer')
        .on('mouseover', function(this: Element) { d3.select(this).attr('fill-opacity', 0.6); })
        .on('mouseout',  function(this: Element) { d3.select(this).attr('fill-opacity', 0.9); })
        .on('click', (event: MouseEvent, d: any) => {
          event.stopPropagation();
          const name = getCityName(d.properties);
          // 毎回最新のフィルター条件で再計算（クロージャの古いcityRatesを使わない）
          const freshRates = aggregateCity(prefName);
          const r = matchCityRate(d.properties, freshRates);
          showPopup(event, name, prefName,
            r ? r.avg : 0, r ? r.count : 0,
            r ? r.vehicles.join('・') : '',
            r ? r.avgBase : 0, r ? r.avgPromo : 0,
            d.properties);
        })
        .transition().duration(400)
        .attr('fill-opacity', 0.9);

      // 市区町村名ラベル — 全市区町村、重複除去
      const labelLayer = g.select('.city-labels');
      labelLayer.selectAll('*').remove();

      const seen = new Set<string>();
      const labelFeatures = mainlandFeatures.filter((d: any) => {
        try {
          const c = pathFn.centroid(d);
          if (!c || !isFinite(c[0]) || !isFinite(c[1])) return false;
          const name = getCityName(d.properties);
          if (!name || seen.has(name)) return false;
          seen.add(name);
          return true;
        } catch { return false; }
      });

      // 現在のズームレベルに合わせたフォントサイズ
      const currentK = d3.zoomTransform(svg.node()).k || 1;
      labelLayer.selectAll('text')
        .data(labelFeatures)
        .enter().append('text')
        .attr('x', (d: any) => pathFn.centroid(d)[0])
        .attr('y', (d: any) => pathFn.centroid(d)[1])
        .attr('text-anchor', 'middle')
        .attr('dominant-baseline', 'central')
        .attr('font-size', `${10 / currentK}px`)
        .attr('font-family', 'sans-serif')
        .attr('font-weight', '500')
        .attr('fill', '#1e293b')
        .attr('pointer-events', 'none')
        .attr('opacity', 0)
        .text((d: any) => {
          const gun = d.properties.N03_003 || '';
          const city = d.properties.N03_004 || '';
          // N03_003（郡/市）とN03_004（町村/区）が両方あれば町村/区名だけ表示
          // 例: 西春日井郡+豊山町→豊山町、名古屋市+中区→中区
          // N03_004だけの場合はそのまま（蒲郡市、郡山市、大和郡山市 等）
          if (gun && city) return city;
          return city || gun;
        })
        .transition().delay(300).duration(300)
        .attr('opacity', 1);

      // ズームフィット: 内陸の密集部分に合わせる（離島を除外）
      const wrap = document.getElementById('map-wrap')!;
      const W = wrap.offsetWidth, H = wrap.offsetHeight;
      let fitBounds: [[number,number],[number,number]];

      // 各featureのcentroid(SVG座標)を集めてIQRで外れ値を除外
      const centroids: {x: number; y: number; f: any}[] = [];
      for (const f of mainlandFeatures) {
        try {
          const c = pathFn.centroid(f);
          if (c && isFinite(c[0]) && isFinite(c[1])) centroids.push({x: c[0], y: c[1], f});
        } catch {}
      }

      if (centroids.length > 4) {
        // X座標とY座標それぞれでIQRフィルタ
        const xs = centroids.map(c => c.x).sort((a,b) => a - b);
        const ys = centroids.map(c => c.y).sort((a,b) => a - b);
        const q = (arr: number[], p: number) => arr[Math.floor(arr.length * p)];
        const iqrX = q(xs, 0.75) - q(xs, 0.25);
        const iqrY = q(ys, 0.75) - q(ys, 0.25);
        const loX = q(xs, 0.25) - iqrX * 1.5;
        const hiX = q(xs, 0.75) + iqrX * 1.5;
        const loY = q(ys, 0.25) - iqrY * 1.5;
        const hiY = q(ys, 0.75) + iqrY * 1.5;
        const inliers = centroids.filter(c => c.x >= loX && c.x <= hiX && c.y >= loY && c.y <= hiY);
        const fitTarget = inliers.length > 0 ? inliers.map(c => c.f) : mainlandFeatures;

        let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
        for (const f of fitTarget) {
          try {
            const b = pathFn.bounds(f);
            if (b[0][0] < minX) minX = b[0][0];
            if (b[0][1] < minY) minY = b[0][1];
            if (b[1][0] > maxX) maxX = b[1][0];
            if (b[1][1] > maxY) maxY = b[1][1];
          } catch {}
        }
        const padX = (maxX - minX) * 0.15;
        const padY = (maxY - minY) * 0.15;
        fitBounds = [[minX - padX, minY - padY], [maxX + padX, maxY + padY]];
      } else if (centroids.length > 0) {
        let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
        for (const f of mainlandFeatures) {
          try {
            const b = pathFn.bounds(f);
            if (b[0][0] < minX) minX = b[0][0];
            if (b[0][1] < minY) minY = b[0][1];
            if (b[1][0] > maxX) maxX = b[1][0];
            if (b[1][1] > maxY) maxY = b[1][1];
          } catch {}
        }
        const padX = (maxX - minX) * 0.15;
        const padY = (maxY - minY) * 0.15;
        fitBounds = [[minX - padX, minY - padY], [maxX + padX, maxY + padY]];
      } else {
        fitBounds = pathFn.bounds(prefFeature);
      }

      const dx = fitBounds[1][0] - fitBounds[0][0];
      const dy = fitBounds[1][1] - fitBounds[0][1];
      const scale = 0.85 / Math.max(dx / W, dy / H);
      const cx = (fitBounds[0][0] + fitBounds[1][0]) / 2;
      const cy = (fitBounds[0][1] + fitBounds[1][1]) / 2;

      // 市区町村モード中のズームアウト制限: フィットスケールの8割まで
      const minScale = scale * 0.8;
      zoom.scaleExtent([minScale, 40]);

      svg.transition().duration(600).call(
        zoom.transform,
        d3.zoomIdentity.translate(W / 2 - scale * cx, H / 2 - scale * cy).scale(scale)
      );

    } catch (err) {
      console.error('[map] drillDown error:', err);
      g.select('.pref-layer').selectAll('path')
        .transition().duration(200)
        .attr('fill-opacity', 1).attr('stroke-opacity', 1);
      // エラー時はナビを都道府県モードに戻す
      btnPref.className = 'bg-blue-600 text-white backdrop-blur rounded-lg shadow px-2.5 py-1.5 text-xs font-bold border border-blue-600 transition-colors';
      btnCity.className = 'bg-white/95 text-gray-400 backdrop-blur rounded-lg shadow px-2.5 py-1.5 text-xs font-bold border border-gray-200 transition-colors cursor-not-allowed';
      btnCity.textContent = '📍 市区町村';
      (btnCity as HTMLButtonElement).disabled = true;
      activePref = null;
    } finally {
      document.getElementById('city-loading')!.classList.add('hidden');
    }
  }

  // ===== ズーム時の自動ドリルダウン =====
  function autoDrillByCenter(transform: any) {
    if (activePref) return;
    const wrap = document.getElementById('map-wrap')!;
    const cx = (wrap.offsetWidth / 2 - transform.x) / transform.k;
    const cy = (wrap.offsetHeight / 2 - transform.y) / transform.k;
    // 画面中央に最も近い都道府県を探す
    let bestDist = Infinity, bestFeature: any = null, bestName = '';
    g.select('.pref-layer').selectAll('path').each(function(d: any) {
      try {
        const c = pathFn.centroid(d);
        const dist = Math.hypot(c[0] - cx, c[1] - cy);
        if (dist < bestDist) { bestDist = dist; bestFeature = d; bestName = getPrefNameJa(d.properties); }
      } catch {}
    });
    if (bestName && bestFeature) {
      drillDown(bestName, bestFeature);
    }
  }

  // ===== 都道府県モードに戻る =====
  function resetToPrefs() {
    activePref = null;
    resettingToPref = true; // ズームトランジション中の自動ドリル防止
    zoom.scaleExtent([0.8, 40]); // 都道府県モード用の広いズーム範囲に復元
    g.select('.city-layer').selectAll('*').remove();
    g.select('.city-labels').selectAll('*').remove();
    const prefRates = aggregatePref();
    g.select('.pref-layer').selectAll('path')
      .transition().duration(300)
      .attr('fill-opacity', 1)
      .attr('stroke-opacity', 1)
      .attr('fill', (d: any) => {
        const jaName = getPrefNameJa(d.properties);
        if (!UBER_AREA[jaName]) return '#1e1e1e';
        const r = prefRates.get(jaName);
        return r ? rateColor(r.avg) : '#e2e8f0';
      });
    svg.transition().duration(400)
      .call(zoom.transform, d3.zoomIdentity)
      .on('end', () => { resettingToPref = false; }); // トランジション完了後にフラグ解除

    // ナビボタン: 都道府県タブをアクティブに
    const btnP = document.getElementById('map-btn-pref')!;
    const btnC = document.getElementById('map-btn-city')!;
    btnP.className = 'bg-blue-600 text-white backdrop-blur rounded-lg shadow px-2.5 py-1.5 text-xs font-bold border border-blue-600 transition-colors';
    btnC.className = 'bg-white/95 text-gray-400 backdrop-blur rounded-lg shadow px-2.5 py-1.5 text-xs font-bold border border-gray-200 transition-colors cursor-not-allowed';
    btnC.textContent = '📍 市区町村';
    (btnC as HTMLButtonElement).disabled = true;
  }

  // ポップアップは下部固定のため位置計算不要

  // ===== ポップアップ =====

  // ポップアップ内容だけを更新するヘルパー（フィルター切替時にも呼ばれる）
  function updatePopupContent(name: string, pref: string, avg: number, count: number, vehicles: string, avgBase?: number, avgPromo?: number) {
    document.getElementById('pp-city')!.textContent = name || '（名称不明）';
    document.getElementById('pp-pref')!.textContent = pref || '';
    const rEl = document.getElementById('pp-rate')!;
    const tEl = document.getElementById('pp-tier')!;
    const bdEl = document.getElementById('pp-breakdown')!;
    if (avg > 0) {
      const col = rateColor(avg);
      rEl.textContent = `¥${avg.toLocaleString()}/h`;
      rEl.style.color = col;
      tEl.textContent = rateLabel(avg);
      tEl.style.background = col + '22';
      tEl.style.color = col;
      document.getElementById('pp-count')!.textContent   = `投稿数: ${count}件`;
      document.getElementById('pp-vehicle')!.textContent = vehicles ? `乗り物: ${vehicles}` : '';
      if (avgBase || avgPromo) {
        document.getElementById('pp-base')!.textContent  = `¥${(avgBase || 0).toLocaleString()}`;
        document.getElementById('pp-promo')!.textContent = `¥${(avgPromo || 0).toLocaleString()}`;
        bdEl.classList.remove('hidden');
      } else {
        bdEl.classList.add('hidden');
      }
    } else {
      rEl.textContent = 'データなし'; rEl.style.color = '#94a3b8';
      tEl.textContent = '';
      document.getElementById('pp-count')!.textContent   = '投稿がありません';
      document.getElementById('pp-vehicle')!.textContent = '';
      bdEl.classList.add('hidden');
    }
  }

  function showPopup(
    event: MouseEvent, name: string, pref: string,
    avg: number, count: number, vehicles: string,
    avgBase?: number, avgPromo?: number,
    cityProps?: any
  ) {
    popupVisible = true;

    // フィルター切替時の再描画用に地域情報を保存
    popupCityName = name;
    popupPrefName = pref;
    popupCityProps = cityProps || null;

    updatePopupContent(name, pref, avg, count, vehicles, avgBase, avgPromo);

    document.getElementById('map-popup')!.classList.remove('hidden');
    event.stopPropagation();
  }
  // ポップアップを閉じるヘルパー
  function hidePopup() {
    document.getElementById('map-popup')?.classList.add('hidden');
    popupVisible = false;
    popupSvgX = null;
    popupSvgY = null;
    popupCityName = '';
    popupPrefName = '';
    popupCityProps = null;
  }
  // マップ背景クリックで閉じる
  document.getElementById('map-wrap')?.addEventListener('click', hidePopup);
  // ✕ボタンで閉じる
  document.getElementById('pp-close')?.addEventListener('click', (e) => {
    e.stopPropagation();
    hidePopup();
  });

  // ===== マップ色を再描画 =====
  function refreshMapColors() {
    if (!d3 || !g) return;
    if (activePref) {
      const cityRates = aggregateCity(activePref);
      // トランジションなしで即時反映
      g.select('.city-layer').selectAll('path')
        .attr('fill', (d: any) => {
          const name = getCityName(d.properties);
          if (!isUberArea(activePref, name)) return '#1e1e1e';
          const r = matchCityRate(d.properties, cityRates);
          return r ? rateColor(r.avg) : '#e2e8f0';
        });

      // ★ ポップアップが表示中なら内容も即時更新
      if (popupVisible && popupCityProps) {
        const r = matchCityRate(popupCityProps, cityRates);
        updatePopupContent(
          popupCityName, popupPrefName,
          r ? r.avg : 0, r ? r.count : 0,
          r ? r.vehicles.join('・') : '',
          r ? r.avgBase : 0, r ? r.avgPromo : 0
        );
      }
    } else {
      const prefRates = aggregatePref();
      // トランジションなしで即時反映
      g.select('.pref-layer').selectAll('path')
        .attr('fill', (d: any) => {
          const jaName = getPrefNameJa(d.properties);
          if (!UBER_AREA[jaName]) return '#1e1e1e';
          const r = prefRates.get(jaName);
          return r ? rateColor(r.avg) : '#e2e8f0';
        });

      // ★ 都道府県モードでポップアップが表示中なら更新
      if (popupVisible && popupPrefName && !popupCityProps) {
        const r = prefRates.get(popupPrefName);
        updatePopupContent(
          popupCityName, '',
          r ? r.avg : 0, r ? r.count : 0,
          r ? r.vehicles.join('・') : ''
        );
      }
    }
  }

  // ===== データ更新 =====
  window.addEventListener('uber-data-updated', () => refreshMapColors());

  // ===== フィルターボタン =====
  function setupFilterButtons() {
    const activeClass = 'bg-blue-600 text-white';
    const inactiveClass = 'bg-gray-100 text-gray-500 hover:bg-gray-200';

    document.querySelectorAll('.map-day-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation(); // map-wrapへのバブルアップを防止（ポップアップが閉じるのを防ぐ）
        filterDay = (btn as HTMLElement).dataset.day || 'all';
        document.querySelectorAll('.map-day-btn').forEach(b => {
          b.className = `map-day-btn text-[10px] px-1.5 py-0.5 rounded font-bold ${inactiveClass}`;
        });
        btn.className = `map-day-btn text-[10px] px-1.5 py-0.5 rounded font-bold ${activeClass}`;
        refreshMapColors();
      });
    });

    document.querySelectorAll('.map-veh-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation(); // map-wrapへのバブルアップを防止（ポップアップが閉じるのを防ぐ）
        filterVehicle = (btn as HTMLElement).dataset.vehicle || 'all';
        document.querySelectorAll('.map-veh-btn').forEach(b => {
          b.className = `map-veh-btn text-[10px] px-1.5 py-0.5 rounded font-bold ${inactiveClass}`;
        });
        btn.className = `map-veh-btn text-[10px] px-1.5 py-0.5 rounded font-bold ${activeClass}`;
        refreshMapColors();
      });
    });
  }
  setupFilterButtons();

  // ===== 起動 =====
  async function initMap() {
    const setMsg = (t: string) => {
      const el = document.getElementById('loading-msg');
      if (el) el.textContent = t;
    };
    try {
      setMsg('D3.js を読み込み中...');
      await loadScript('https://cdnjs.cloudflare.com/ajax/libs/d3/7.9.0/d3.min.js', 'd3');
      d3 = (window as any).d3;

      setMsg('地図データを取得中...');
      const PREF_URL = 'https://cdn.jsdelivr.net/gh/dataofjapan/land@master/japan.geojson';
      const prefData = await d3.json(PREF_URL);

      document.getElementById('map-loading')!.style.display = 'none';
      buildMap(prefData);
      console.log('[map] init complete');

    } catch (err) {
      console.error('[map] init error:', err);
      const el = document.getElementById('map-loading')!;
      el.innerHTML = `
        <div class="text-center px-6">
          <div class="text-3xl mb-2">⚠️</div>
          <p class="text-sm text-slate-600 font-medium mb-1">地図データの取得に失敗しました</p>
          <p class="text-xs text-slate-400 leading-relaxed">インターネット接続を確認してリロード</p>
        </div>`;
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMap);
  } else {
    initMap();
  }
</script>
