---
const navLinks = [
  { label: 'ホーム', href: '/' },
  { label: '🚗 Uber稼ぎ方', href: '/category/uber', color: 'text-green-700 hover:bg-green-50' },
  { label: '💳 クレカ修行', href: '/category/credit-card', color: 'text-blue-700 hover:bg-blue-50' },
  { label: '📊 扶養・税金', href: '/category/tax', color: 'text-orange-700 hover:bg-orange-50' },
  { label: '🗾 時給マップ', href: '/data', color: 'text-teal-700 hover:bg-teal-50' },
  { label: '📋 始め方', href: '/roadmap', color: 'text-purple-700 hover:bg-purple-50' },
];
---

<header class="bg-white shadow-sm sticky top-0 z-50">
  <div class="max-w-5xl mx-auto px-4">
    <div class="flex items-center justify-between h-14">

      <!-- ロゴ -->
      <a href="/" class="flex items-center gap-1.5 text-primary-700 font-bold text-base whitespace-nowrap">
        <span class="text-xl leading-none">🛵</span>
        ひろブログ
      </a>

      <!-- デスクトップナビ -->
      <nav class="hidden md:flex items-center gap-0.5" aria-label="メインナビゲーション">
        {navLinks.map(({ label, href, color }) => (
          <a
            href={href}
            class={`text-sm px-3 py-2 rounded-lg transition-colors font-medium ${color}`}
          >
            {label}
          </a>
        ))}
      </nav>

      <!-- ハンバーガーボタン（モバイル） -->
      <button
        id="menu-toggle"
        class="md:hidden p-2 rounded-lg text-gray-600 hover:bg-gray-100 transition-colors"
        aria-label="メニューを開く"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- モバイルメニュー -->
  <div
    id="mobile-menu"
    class="md:hidden hidden border-t border-gray-100 bg-white"
    aria-label="モバイルナビゲーション"
  >
    <!-- カテゴリバッジ（3つ横並び） -->
    <div class="px-4 pt-3 pb-2 grid grid-cols-3 gap-2">
      <a href="/category/uber"
        class="flex flex-col items-center gap-1 bg-green-50 text-green-700 border border-green-200 px-2 py-3 rounded-xl font-semibold text-xs text-center">
        <span class="text-xl">🚗</span>
        Uber稼ぎ方
      </a>
      <a href="/category/credit-card"
        class="flex flex-col items-center gap-1 bg-blue-50 text-blue-700 border border-blue-200 px-2 py-3 rounded-xl font-semibold text-xs text-center">
        <span class="text-xl">💳</span>
        クレカ修行
      </a>
      <a href="/category/tax"
        class="flex flex-col items-center gap-1 bg-orange-50 text-orange-700 border border-orange-200 px-2 py-3 rounded-xl font-semibold text-xs text-center">
        <span class="text-xl">📊</span>
        扶養・税金
      </a>
    </div>
    <nav class="px-4 pb-3 flex flex-col gap-1 border-t border-gray-100 pt-2">
      <a href="/" class="text-sm text-gray-700 hover:text-primary-600 hover:bg-primary-50 px-3 py-2 rounded-lg transition-colors">
        ホーム
      </a>
      <a href="/about" class="text-sm text-gray-700 hover:text-primary-600 hover:bg-primary-50 px-3 py-2 rounded-lg transition-colors">
        このブログについて
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle')!;
  const menu = document.getElementById('mobile-menu')!;
  const iconOpen = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  toggle.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden', isOpen);
    iconOpen.classList.toggle('hidden', !isOpen);
    iconClose.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
