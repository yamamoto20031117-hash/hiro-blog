---
interface Props {
  name: string;
  description: string;
  price: string;
  url: string;
  image?: string;
  badge?: string;   // 例: "人気No.1" / "期間限定" など
  rating?: number;  // 1〜5
}

const { name, description, price, url, image, badge, rating } = Astro.props;

const stars = rating ? Math.round(Math.min(5, Math.max(0, rating))) : null;
---

<div class="border-2 border-primary-200 rounded-xl p-4 bg-gradient-to-br from-white to-primary-50 shadow-sm">

  <!-- バッジ -->
  {badge && (
    <span class="inline-block bg-accent-500 text-white text-xs font-bold px-3 py-1 rounded-full mb-3 shadow">
      {badge}
    </span>
  )}

  <div class="flex gap-4 items-start">
    <!-- 商品画像 -->
    {image ? (
      <div class="flex-shrink-0 w-24 h-24 sm:w-28 sm:h-28 rounded-lg overflow-hidden bg-gray-100 shadow">
        <img src={image} alt={name} class="w-full h-full object-cover" loading="lazy" />
      </div>
    ) : (
      <div class="flex-shrink-0 w-24 h-24 sm:w-28 sm:h-28 rounded-lg bg-gradient-to-br from-primary-100 to-primary-200 flex items-center justify-center">
        <svg class="w-12 h-12 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
            d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
        </svg>
      </div>
    )}

    <!-- 商品情報 -->
    <div class="flex-1 min-w-0">
      <h3 class="font-bold text-gray-900 text-sm sm:text-base leading-snug mb-1">{name}</h3>

      {stars && (
        <div class="flex items-center gap-1 mb-2">
          {Array.from({ length: 5 }, (_, i) => (
            <svg
              class={`w-4 h-4 ${i < stars ? 'text-yellow-400' : 'text-gray-200'}`}
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          ))}
          <span class="text-xs text-gray-500 ml-1">{rating?.toFixed(1)}</span>
        </div>
      )}

      <p class="text-xs sm:text-sm text-gray-600 line-clamp-2 mb-2">{description}</p>

      <div class="flex items-center justify-between gap-2 flex-wrap">
        <span class="text-primary-700 font-bold text-base sm:text-lg">{price}</span>
        <a
          href={url}
          target="_blank"
          rel="noopener noreferrer nofollow"
          class="inline-flex items-center gap-1.5 bg-accent-500 hover:bg-accent-600 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors shadow-sm hover:shadow"
        >
          詳細を見る
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</div>
