---
import { SITE_NAME, SITE_TAGLINE, SITE_LOGO_EMOJI, CATEGORIES } from '@/site';
const year = new Date().getFullYear();
const footerCats = CATEGORIES.slice(0, 2); // コアカテゴリ（ガジェット・家電）
---

<footer class="bg-gray-900 text-gray-300 mt-16">
  <div class="max-w-5xl mx-auto px-4 py-10">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 mb-8">

      <!-- サイト情報 -->
      <div class="col-span-2 sm:col-span-1">
        <h3 class="text-white font-bold mb-3 flex items-center gap-2">
          <span class="text-primary-400 text-lg">{SITE_LOGO_EMOJI}</span>
          {SITE_NAME}
        </h3>
        <p class="text-sm leading-relaxed text-gray-400">
          {SITE_TAGLINE}。ガジェット・家電を実レビューと徹底比較・ランキングで紹介する買い物ガイド。
        </p>
      </div>

      <!-- カテゴリ -->
      <div>
        <h4 class="text-white font-semibold text-sm mb-3">カテゴリ</h4>
        <ul class="space-y-2 text-sm">
          {footerCats.map((c) => (
            <li><a href={`/category/${c.slug}`} class="hover:text-primary-400 transition-colors">{c.icon} {c.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- コンテンツ -->
      <div>
        <h4 class="text-white font-semibold text-sm mb-3">コンテンツ</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/ranking" class="hover:text-primary-400 transition-colors">🔥 ランキング</a></li>
          <li><a href="/products" class="hover:text-primary-400 transition-colors">📝 商品レビュー</a></li>
          <li><a href="/posts" class="hover:text-primary-400 transition-colors">新着記事</a></li>
          <li><a href="/about" class="hover:text-primary-400 transition-colors">このサイトについて</a></li>
        </ul>
      </div>

      <!-- その他 -->
      <div>
        <h4 class="text-white font-semibold text-sm mb-3">その他</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/privacy" class="hover:text-primary-400 transition-colors">プライバシーポリシー</a></li>
          <li><a href="/disclaimer" class="hover:text-primary-400 transition-colors">免責事項</a></li>
          <li><a href="/contact" class="hover:text-primary-400 transition-colors">お問い合わせ</a></li>
        </ul>
      </div>
    </div>

    <!-- アフィリエイト免責 -->
    <div class="border-t border-gray-700 pt-6 mb-4">
      <p class="text-xs text-gray-500 leading-relaxed">
        {SITE_NAME}は、Amazon.co.jpを宣伝しリンクすることによってサイトが紹介料を獲得できる手段を提供することを目的に設定されたアフィリエイトプログラムである、Amazonアソシエイト・プログラムの参加者です。記事内のリンクから商品を購入いただいた場合、当サイトに報酬が発生することがありますが、購入者の費用は増加しません。掲載情報は執筆時点のものです。最新情報は各サービス・商品の公式サイトをご確認ください。
      </p>
    </div>

    <div class="text-center text-xs text-gray-500">
      &copy; {year} {SITE_NAME}. All rights reserved.
    </div>
  </div>
</footer>
